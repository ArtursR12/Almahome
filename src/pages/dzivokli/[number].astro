---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/ui/Container.astro';
import Section from '@/components/ui/Section.astro';
import Button from '@/components/ui/Button.astro';
import PhotoOrPlaceholder from '@/components/ui/PhotoOrPlaceholder.astro';
import ContactForm from '@/components/forms/ContactForm.svelte';
import BottomCTA from '@/components/layout/BottomCTA.astro';
import ApartmentPrintSheet from '@/components/apartments/ApartmentPrintSheet.astro';
import { getLocaleFromUrl, useTranslations, getLocalizedUrl, formatPrice, localizedRoomName, roomsLabel } from '@/i18n/utils';

export const prerender = true;

export async function getStaticPaths() {
  const apartments = await getCollection('apartments');
  return apartments.map((apt) => ({
    params: { number: String(apt.data.number) },
    props: { apt },
  }));
}

const { apt } = Astro.props;
const a = apt.data;
const lang = getLocaleFromUrl(Astro.url);
const t = useTranslations(lang);

import fs from 'node:fs';
import path from 'node:path';
const padded = String(a.number).padStart(2, '0');
const locatorSrc = `/images/floor-plans/apt-${padded}-locator.jpg`;
const locatorExists = (() => {
  try { return fs.statSync(path.join(process.cwd(), 'public', locatorSrc.slice(1))).isFile(); }
  catch { return false; }
})();

const allApts = (await getCollection('apartments')).map((x) => x.data);
const otherAvailable = allApts
  .filter((x) => x.status === 'available' && x.number !== a.number)
  .sort(() => Math.random() - 0.5)
  .slice(0, 3);

const availableSpots = (await getCollection('parking'))
  .map((x) => x.data)
  .filter((s) => s.status === 'available')
  .sort((x, y) => x.number - y.number)
  .map((s) => ({ number: s.number, type: s.type }));

const statusDict = {
  available: { label: t('status.available'),  bg: 'bg-status-available/15', dot: 'bg-status-available', text: 'text-status-available' },
  reserved:  { label: t('status.reserved'),   bg: 'bg-status-reserved/20',  dot: 'bg-status-reserved',  text: 'text-[#8a7531]' },
  sold:      { label: t('status.sold'),       bg: 'bg-status-sold/15',      dot: 'bg-status-sold',      text: 'text-ink-muted' },
} as const;
const status = statusDict[a.status];

const featureLabels: string[] = [
  a.has_terrace ? t('common.terrace') : '',
  a.has_balcony ? t('common.balcony') : '',
].filter(Boolean);
const features = featureLabels.length === 0 ? '—' : featureLabels.join(' · ');

const summary = t('apartment_detail.summary')
  .replace('{floor}', String(a.floor))
  .replace('{rooms}', String(a.rooms))
  .replace('{rooms_label}', roomsLabel(a.rooms, lang))
  .replace('{area}', String(a.area_total));

const pageTitle = `${t('apartment_detail.kicker')} ${t('apartment_detail.label_number')}${a.number} — ${a.rooms} ${roomsLabel(a.rooms, lang)}, ${a.area_total} m² — ALMA HOME`;
const pageDescription = `${a.rooms} ${roomsLabel(a.rooms, lang)} · ${a.floor}. ${t('common.floor_long')} · ${a.area_total} m² · ${formatPrice(a.price, lang, a.status)}. ALMA HOME — Mores iela 15, Rīga.`;

// Apartment schema. Search engines surface bedroom count, area, and price
// directly when this is well-formed.
const siteOrigin = Astro.site ?? new URL('https://almahome.lv');
const apartmentSchema: Record<string, unknown> = {
  '@type': 'Apartment',
  '@id': new URL(`/dzivokli/${a.number}#apartment`, siteOrigin).toString(),
  name: `ALMA HOME — Nr. ${a.number}`,
  description: pageDescription,
  numberOfRooms: a.rooms,
  floorSize: { '@type': 'QuantitativeValue', value: a.area_total, unitCode: 'MTK' },
  floorLevel: String(a.floor),
  url: new URL(`/dzivokli/${a.number}`, siteOrigin).toString(),
  image: new URL(a.floor_plan_image, siteOrigin).toString(),
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Mores iela 15',
    addressLocality: 'Rīga',
    postalCode: 'LV-1034',
    addressCountry: 'LV',
  },
  ...(typeof a.price === 'number' && a.status === 'available'
    ? {
        offers: {
          '@type': 'Offer',
          price: a.price,
          priceCurrency: 'EUR',
          availability: 'https://schema.org/InStock',
        },
      }
    : a.status === 'reserved'
    ? { offers: { '@type': 'Offer', availability: 'https://schema.org/PreOrder', priceCurrency: 'EUR' } }
    : a.status === 'sold'
    ? { offers: { '@type': 'Offer', availability: 'https://schema.org/SoldOut', priceCurrency: 'EUR' } }
    : {}),
};
---
<BaseLayout
  lang={lang}
  title={pageTitle}
  description={pageDescription}
  jsonLd={apartmentSchema}
>
  <!-- Hero -->
  <section class="relative bg-burgundy text-cream overflow-hidden">
    <div class="absolute inset-0 opacity-[0.07] pointer-events-none">
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_rgba(245,239,230,0.5),_transparent_60%)]"></div>
    </div>
    <Container class="relative py-14 md:py-20">
      <a
        href={getLocalizedUrl('/dzivokli', lang)}
        class="inline-flex items-center gap-2 text-xs uppercase tracking-[0.3em] text-cream/75 hover:text-cream transition-colors"
      >
        <svg class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 6l-6 6 6 6" stroke-linecap="round" stroke-linejoin="round"/></svg>
        {t('common.back_to_apartments')}
      </a>
      <div class="mt-5 flex flex-col md:flex-row md:items-end md:justify-between gap-4">
        <div>
          <p class="text-[11px] md:text-xs uppercase tracking-[0.4em] text-cream/70">{t('apartment_detail.kicker')}</p>
          <h1 class="mt-2 font-serif text-5xl md:text-7xl leading-[1.05]">
            {t('apartment_detail.label_number')} <span class="font-light">{a.number}</span>
          </h1>
          <p class="mt-3 text-sm md:text-base text-cream/75">
            {summary}
          </p>
        </div>
        <span class:list={['self-start md:self-end inline-flex items-center gap-2 rounded-full px-3 py-1.5 text-sm bg-cream/95', status.text]}>
          <span class:list={['h-2 w-2 rounded-full', status.dot]} aria-hidden="true"></span>
          {status.label}
        </span>
      </div>
    </Container>
  </section>

  <!-- Info + plan -->
  <Section background="cream">
    <Container>
      <div class="grid lg:grid-cols-5 gap-8 lg:gap-12">
        <!-- Info — order:2 on mobile so the plan reads first; left column on desktop -->
        <div class="lg:col-span-2 space-y-8 order-2 lg:order-1">
          <div>
            <p class="text-xs uppercase tracking-[0.3em] text-ink-muted">{t('apartment_detail.price_label')}</p>
            <p class="mt-2 font-serif text-5xl text-burgundy tabular-nums">{formatPrice(a.price, lang, a.status)}</p>
            {a.price && (
              <p class="mt-1 text-sm text-ink-muted tabular-nums">
                ≈ {Math.round(a.price / a.area_total).toLocaleString(lang === 'en' ? 'en-US' : 'lv-LV')} € / m²
              </p>
            )}
          </div>

          <dl class="grid grid-cols-2 gap-x-6 gap-y-5 border-y border-ink-muted/15 py-6">
            <div>
              <dt class="text-xs uppercase tracking-[0.25em] text-ink-muted">{t('apartment_detail.floor_label')}</dt>
              <dd class="mt-1.5 font-serif text-2xl text-burgundy">{a.floor}.</dd>
            </div>
            <div>
              <dt class="text-xs uppercase tracking-[0.25em] text-ink-muted">{t('apartment_detail.rooms_label')}</dt>
              <dd class="mt-1.5 font-serif text-2xl text-burgundy">{a.rooms}</dd>
            </div>
            <div>
              <dt class="text-xs uppercase tracking-[0.25em] text-ink-muted">{t('apartment_detail.area_label')}</dt>
              <dd class="mt-1.5 font-serif text-2xl text-burgundy tabular-nums">{a.area_total} <span class="text-base text-ink-muted">m²</span></dd>
            </div>
            <div>
              <dt class="text-xs uppercase tracking-[0.25em] text-ink-muted">{t('apartment_detail.features_label')}</dt>
              <dd class="mt-1.5 text-base text-ink">{features}</dd>
            </div>
          </dl>

          <div>
            <p class="text-xs uppercase tracking-[0.25em] text-ink-muted mb-3">{t('apartment_detail.rooms_breakdown_label')}</p>
            <table class="w-full text-sm">
              <tbody>
                {a.rooms_breakdown.map((r) => (
                  <tr class="border-b border-ink-muted/10 last:border-0">
                    <td class="py-2.5 text-ink">{localizedRoomName(r, lang)}</td>
                    <td class="py-2.5 text-right text-ink-muted tabular-nums">{r.area} m²</td>
                  </tr>
                ))}
                <tr class="border-t-2 border-ink-muted/30">
                  <td class="pt-3 font-medium text-ink">{t('common.kopa')}</td>
                  <td class="pt-3 text-right font-medium text-burgundy tabular-nums">{a.area_total} m²</td>
                </tr>
              </tbody>
            </table>
          </div>

          {locatorExists && (
            <div>
              <p class="text-xs uppercase tracking-[0.25em] text-ink-muted mb-3">{t('apartment_detail.locator_label')}</p>
              <img
                src={locatorSrc}
                alt={`Nr. ${a.number} — ${t('apartment_detail.locator_label')}`}
                width="600"
                height="370"
                loading="lazy"
                class="w-full h-auto rounded-xl border border-burgundy/10 max-w-[480px]"
              />
            </div>
          )}

          {a.status === 'available' && (
            <Button variant="primary" size="lg" href="#pieteikuma-forma" class="w-full !justify-center js-smooth-scroll">
              {t('apartment_detail.request_cta')}
            </Button>
          )}
        </div>

        <!-- Plan image — order:1 on mobile so it reads first; right column on desktop -->
        <div class="lg:col-span-3 order-1 lg:order-2">
          <div class="rounded-xl bg-beige/50 p-4 md:p-8 lg:sticky lg:top-24">
            <PhotoOrPlaceholder
              src={a.floor_plan_image}
              width={1000}
              height={750}
              alt={`Nr. ${a.number}`}
              label={`${t('apartment_detail.card_plan_label')}${a.number}`}
              class="w-full h-auto object-contain max-h-[60vh] lg:max-h-[70vh] mx-auto"
            />
            <div class="mt-4 flex justify-end">
              <button
                type="button"
                class="js-print-plan inline-flex items-center gap-2 text-sm text-burgundy hover:text-burgundy-dark transition-colors group"
              >
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M6 9V2h12v7" />
                  <rect x="6" y="14" width="12" height="8" rx="1" />
                  <path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2" />
                </svg>
                <span class="border-b border-burgundy/30 group-hover:border-burgundy-dark/60">{t('apartment_detail.print_cta')}</span>
              </button>
            </div>
          </div>
        </div>
      </div>
    </Container>
  </Section>

  <!-- Renders -->
  {a.render_images && a.render_images.length > 0 && (
    <Section background="beige">
      <Container>
        <div class="text-center mb-10">
          <p class="text-xs uppercase tracking-[0.3em] text-ink-muted">{t('apartment_detail.renders_kicker')}</p>
          <h2 class="mt-3 font-serif text-3xl md:text-4xl text-burgundy">{t('apartment_detail.renders_title')}</h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-6">
          {a.render_images.map((src, i) => (
            <div class="rounded-xl overflow-hidden bg-cream aspect-[4/3]">
              <img
                src={src}
                alt={`Nr. ${a.number} — render ${i + 1}`}
                loading="lazy"
                class="h-full w-full object-cover"
              />
            </div>
          ))}
        </div>
      </Container>
    </Section>
  )}

  <!-- Application form -->
  <Section background="beige" id="pieteikuma-forma">
    <Container>
      <div class="max-w-2xl mx-auto">
        <div class="text-center mb-10">
          <p class="text-xs uppercase tracking-[0.3em] text-ink-muted">{t('apartment_detail.kicker')}</p>
          <h2 class="mt-3 font-serif text-3xl md:text-4xl text-burgundy">{t('form.title_apt')}</h2>
          <p class="mt-3 text-ink-muted">
            {t('form.subtitle_apt')}
          </p>
        </div>

        <div class="bg-cream rounded-xl p-6 md:p-8">
          <ContactForm apartmentNumber={a.number} availableSpots={availableSpots} lang={lang} client:load />
        </div>
      </div>
    </Container>
  </Section>

  <script>
    document.querySelectorAll<HTMLAnchorElement>('a.js-smooth-scroll[href^="#"]').forEach((a) => {
      a.addEventListener('click', (e) => {
        const target = document.querySelector(a.getAttribute('href')!);
        if (!target) return;
        e.preventDefault();
        target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
    });
    document.querySelectorAll<HTMLButtonElement>('button.js-print-plan').forEach((btn) => {
      btn.addEventListener('click', () => window.print());
    });
  </script>

  <ApartmentPrintSheet
    number={a.number}
    floor={a.floor}
    rooms={a.rooms}
    area_total={a.area_total}
    price={a.price}
    status={a.status}
    has_terrace={a.has_terrace}
    has_balcony={a.has_balcony}
    rooms_breakdown={a.rooms_breakdown}
    floor_plan_image={a.floor_plan_image}
    lang={lang}
  />

  <!-- Other available -->
  {otherAvailable.length > 0 && (
    <Section background="cream">
      <Container>
        <div class="flex items-end justify-between gap-4 mb-10">
          <div>
            <p class="text-xs uppercase tracking-[0.3em] text-ink-muted">{t('apartment_detail.other_kicker')}</p>
            <h2 class="mt-3 font-serif text-3xl md:text-4xl text-burgundy">{t('apartment_detail.other_title')}</h2>
          </div>
          <a href={getLocalizedUrl('/dzivokli', lang)} class="hidden sm:inline-block text-sm text-burgundy hover:underline underline-offset-4">{t('apartment_detail.other_link_all')}</a>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {otherAvailable.map((o) => (
            <a
              href={getLocalizedUrl(`/dzivokli/${o.number}`, lang)}
              class="group bg-beige rounded-xl overflow-hidden flex flex-col transition-shadow hover:shadow-lg"
            >
              <div class="relative aspect-[4/3] overflow-hidden bg-cream">
                <PhotoOrPlaceholder
                  src={o.floor_plan_image}
                  width={400}
                  height={300}
                  alt={`Nr. ${o.number}`}
                  label={`${t('apartment_detail.card_plan_label')}${o.number}`}
                  class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-[1.03]"
                />
              </div>
              <div class="p-5 flex-1 flex flex-col">
                <div class="flex items-baseline justify-between">
                  <h3 class="font-serif text-2xl text-burgundy">Nr. {o.number}</h3>
                  <span class="text-sm text-ink-muted">{o.floor}. {t('common.floor_long')}</span>
                </div>
                <div class="mt-2 text-sm text-ink-muted">
                  {o.rooms} {roomsLabel(o.rooms, lang)} · {o.area_total} m²{o.has_terrace ? ` · ${t('common.terrace')}` : o.has_balcony ? ` · ${t('common.balcony')}` : ''}
                </div>
                <div class="mt-4 flex items-end justify-between">
                  <span class="font-serif text-xl text-burgundy">{formatPrice(o.price, lang, o.status)}</span>
                  <span class="text-sm text-burgundy group-hover:underline">{t('common.see')} →</span>
                </div>
              </div>
            </a>
          ))}
        </div>
      </Container>
    </Section>
  )}

  <BottomCTA lang={lang} background={otherAvailable.length > 0 ? 'beige' : 'cream'} />
</BaseLayout>
