---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/ui/Container.astro';
import Section from '@/components/ui/Section.astro';
import BottomCTA from '@/components/layout/BottomCTA.astro';
import floorPlansData from '@/data/floor-plans.json';
import { getLocaleFromUrl, useTranslations, getLocalizedUrl, formatPrice, roomsLabel } from '@/i18n/utils';

const lang = getLocaleFromUrl(Astro.url);
const t = useTranslations(lang);

const apartments = (await getCollection('apartments')).sort((a, b) => a.data.number - b.data.number);

const counts = {
  available: apartments.filter((a) => a.data.status === 'available').length,
  reserved:  apartments.filter((a) => a.data.status === 'reserved').length,
  sold:      apartments.filter((a) => a.data.status === 'sold').length,
  total:     apartments.length,
};

const aptByNumber = new Map(apartments.map((a) => [a.data.number, a.data]));

const floors = floorPlansData.floors.map((f) => ({
  floor: f.floor,
  image: f.image,
  width: floorPlansData.image_width,
  height: floorPlansData.image_height,
  shapes: f.apartments.map((p) => {
    const apt = aptByNumber.get(p.number)!;
    return { number: p.number, polygon: p.polygon, apt };
  }),
  apartments: apartments.filter((a) => a.data.floor === f.floor).map((a) => a.data),
}));

const statusDict = {
  available: { label: t('status.available'),  bg: 'bg-status-available/15',  dot: 'bg-status-available',  text: 'text-status-available' },
  reserved:  { label: t('status.reserved'),   bg: 'bg-status-reserved/20',   dot: 'bg-status-reserved',   text: 'text-[#8a7531]' },
  sold:      { label: t('status.sold'),       bg: 'bg-status-sold/15',       dot: 'bg-status-sold',       text: 'text-ink-muted' },
} as const;

const statusLabelPlural = {
  available: t('status.available_plural'),
  reserved:  t('status.reserved_plural'),
  sold:      t('status.sold_plural'),
};

function floorLabel(n: number): string {
  return t('dzivokli.floor_label').replace('{n}', String(n));
}

function aptDetailHref(n: number): string {
  return getLocalizedUrl(`/dzivokli/${n}`, lang);
}

function notesFor(a: { has_terrace: boolean; has_balcony: boolean }): string {
  return [
    a.has_terrace ? t('common.terrace') : null,
    a.has_balcony ? t('common.balcony') : null,
  ].filter(Boolean).join(' · ') || '—';
}
---
<BaseLayout
  lang={lang}
  title={t('dzivokli.title')}
  description={t('dzivokli.description')}
>
  <Section background="cream" class="!pt-16 md:!pt-20">
    <Container>
      <!-- Heading -->
      <div class="text-center mb-10">
        <p class="text-xs uppercase tracking-[0.3em] text-ink-muted">{t('dzivokli.hero_kicker')}</p>
        <h1 class="mt-4 font-serif text-5xl md:text-6xl text-burgundy">{t('dzivokli.hero_title')}</h1>
        <p class="mt-4 text-ink-muted max-w-2xl mx-auto">
          {t('dzivokli.hero_subtitle')}
        </p>
      </div>

      <!-- Floor plans -->
      <div id="floor-plans" class="mb-12">
        <div class="flex flex-wrap items-center justify-between gap-4 mb-5">
          <p class="text-xs uppercase tracking-[0.25em] text-ink-muted">{t('dzivokli.floor_plans_kicker')}</p>
          <div role="tablist" aria-label={t('dzivokli.floor_plans_kicker')} class="flex gap-2 bg-beige/60 rounded-full p-1">
            {floors.map((f, i) => (
              <button
                type="button"
                role="tab"
                aria-selected={i === 0 ? 'true' : 'false'}
                aria-controls={`floor-panel-${f.floor}`}
                id={`floor-tab-${f.floor}`}
                data-floor-tab={f.floor}
                class:list={[
                  'floor-tab inline-flex items-center justify-center px-5 py-2 rounded-full text-sm font-medium transition-colors',
                  i === 0 ? 'bg-burgundy text-cream' : 'text-ink hover:text-burgundy',
                ]}
              >
                {floorLabel(f.floor)}
              </button>
            ))}
          </div>
        </div>

        {floors.map((f, i) => (
          <div
            id={`floor-panel-${f.floor}`}
            role="tabpanel"
            aria-labelledby={`floor-tab-${f.floor}`}
            data-floor-panel={f.floor}
            class:list={['floor-panel', i !== 0 && 'hidden']}
          >
            <div class="rounded-2xl bg-cream border border-ink-muted/15 p-4 md:p-6">
              <svg
                viewBox={`0 0 ${f.width} ${f.height}`}
                role="img"
                aria-label={floorLabel(f.floor)}
                class="w-full h-auto select-none"
              >
                <image href={f.image} width={f.width} height={f.height} />
                {f.shapes.map(({ number, polygon, apt }) => {
                  const status = apt.status;
                  const fillClass =
                    status === 'available' ? 'fill-status-available' :
                    status === 'reserved'  ? 'fill-status-reserved'  :
                                             'fill-status-sold';
                  const clickable = status === 'available';
                  return (
                    <a
                      href={clickable ? aptDetailHref(number) : undefined}
                      aria-label={`Nr.${number} — ${statusDict[status].label}`}
                    >
                      <polygon
                        points={polygon}
                        class:list={[
                          'apt-polygon transition-opacity',
                          fillClass,
                          clickable ? 'cursor-pointer' : 'cursor-not-allowed',
                        ]}
                        fill-opacity="0.18"
                        stroke="transparent"
                        stroke-width="2"
                        data-number={number}
                        data-status={status}
                        data-status-label={statusDict[status].label}
                        data-rooms={apt.rooms}
                        data-rooms-label={roomsLabel(apt.rooms, lang)}
                        data-area={apt.area_total}
                        data-price={formatPrice(apt.price, lang)}
                        data-floor={apt.floor}
                        data-floor-label={floorLabel(apt.floor)}
                      />
                    </a>
                  );
                })}
              </svg>
            </div>
            <div class="mt-5 flex flex-wrap gap-2" data-floor-chips>
              {f.apartments.map((a) => {
                const s = statusDict[a.status];
                const clickable = a.status === 'available';
                return (
                  <a
                    href={clickable ? aptDetailHref(a.number) : '#'}
                    aria-disabled={clickable ? undefined : 'true'}
                    title={`Nr.${a.number} · ${a.area_total} m² · ${s.label}`}
                    class:list={[
                      'inline-flex items-center gap-2 rounded-full border px-3.5 py-1.5 text-sm transition-colors',
                      clickable
                        ? 'border-ink-muted/20 bg-cream hover:border-burgundy hover:text-burgundy'
                        : 'border-ink-muted/10 bg-cream/60 pointer-events-none opacity-60',
                    ]}
                  >
                    <span class:list={['h-2 w-2 rounded-full', s.dot]} aria-hidden="true"></span>
                    <span class="font-serif text-burgundy">Nr.{a.number}</span>
                    <span class="text-ink-muted text-xs">· {a.area_total} m²</span>
                  </a>
                );
              })}
            </div>
          </div>
        ))}
      </div>

      <!-- Status legend -->
      <div class="flex flex-wrap justify-center gap-x-8 gap-y-3 mb-12">
        {(['available', 'reserved', 'sold'] as const).map((key) => {
          const s = statusDict[key];
          const n = counts[key];
          return (
            <div class="flex items-center gap-3 text-sm">
              <span class:list={['inline-block h-3 w-3 rounded-full', s.dot]} aria-hidden="true"></span>
              <span class="text-ink">{s.label}</span>
              <span class="text-ink-muted tabular-nums">— {n}</span>
            </div>
          );
        })}
      </div>

      <!-- Filters -->
      <form id="apt-filters" class="bg-beige/60 rounded-xl p-5 md:p-7 mb-8 grid grid-cols-1 md:grid-cols-4 gap-5 md:gap-8" novalidate>
        <fieldset>
          <legend class="text-xs uppercase tracking-[0.25em] text-ink-muted mb-3">{t('dzivokli.filter_floor')}</legend>
          <div class="flex flex-wrap gap-2">
            {[1, 2, 3].map((f) => (
              <label class="filter-chip">
                <input type="checkbox" name="floor" value={f} class="peer sr-only" />
                <span>{f}.</span>
              </label>
            ))}
          </div>
        </fieldset>

        <fieldset>
          <legend class="text-xs uppercase tracking-[0.25em] text-ink-muted mb-3">{t('dzivokli.filter_rooms')}</legend>
          <div class="flex flex-wrap gap-2">
            {[1, 2, 3, 4].map((r) => (
              <label class="filter-chip">
                <input type="checkbox" name="rooms" value={r} class="peer sr-only" />
                <span>{r}</span>
              </label>
            ))}
          </div>
        </fieldset>

        <fieldset>
          <legend class="text-xs uppercase tracking-[0.25em] text-ink-muted mb-3">{t('dzivokli.filter_features')}</legend>
          <div class="flex flex-wrap gap-2">
            <label class="filter-chip">
              <input type="checkbox" name="terrace" class="peer sr-only" />
              <span>{t('common.terrace').replace(/^./, c => c.toUpperCase())}</span>
            </label>
            <label class="filter-chip">
              <input type="checkbox" name="balcony" class="peer sr-only" />
              <span>{t('common.balcony').replace(/^./, c => c.toUpperCase())}</span>
            </label>
          </div>
        </fieldset>

        <fieldset>
          <legend class="text-xs uppercase tracking-[0.25em] text-ink-muted mb-3">{t('dzivokli.filter_status')}</legend>
          <div class="flex flex-wrap gap-2">
            <label class="filter-chip" data-status="available">
              <input type="checkbox" name="status" value="available" class="peer sr-only" checked />
              <span>{statusLabelPlural.available}</span>
            </label>
            <label class="filter-chip" data-status="reserved">
              <input type="checkbox" name="status" value="reserved" class="peer sr-only" checked />
              <span>{statusLabelPlural.reserved}</span>
            </label>
            <label class="filter-chip" data-status="sold">
              <input type="checkbox" name="status" value="sold" class="peer sr-only" />
              <span>{statusLabelPlural.sold}</span>
            </label>
          </div>
        </fieldset>

        <div class="md:col-span-4 flex flex-wrap items-center justify-between gap-3 pt-2 border-t border-ink-muted/15">
          <p class="text-sm text-ink-muted">
            <span set:html={t('dzivokli.filter_count')
              .replace('{n}', `<span id="filter-count" class="font-medium text-ink tabular-nums">${counts.available + counts.reserved}</span>`)
              .replace('{total}', `<span class="tabular-nums">${counts.total}</span>`)} />
          </p>
          <button type="reset" class="text-sm text-burgundy hover:underline underline-offset-4">
            {t('dzivokli.filter_clear')}
          </button>
        </div>
      </form>

      <!-- Table (desktop) -->
      <div class="hidden md:block rounded-xl overflow-hidden border border-ink-muted/15 bg-cream">
        <table class="w-full text-left">
          <thead class="bg-beige/70 text-xs uppercase tracking-[0.18em] text-ink-muted">
            <tr>
              <th class="px-5 py-4 w-20">{t('dzivokli.table_number')}</th>
              <th class="px-5 py-4 w-20">{t('dzivokli.table_floor')}</th>
              <th class="px-5 py-4 w-24">{t('dzivokli.table_rooms')}</th>
              <th class="px-5 py-4 w-28">{t('dzivokli.table_area')}</th>
              <th class="px-5 py-4">{t('dzivokli.table_price')}</th>
              <th class="px-5 py-4">{t('dzivokli.table_notes')}</th>
              <th class="px-5 py-4 w-32 text-right pr-6">{t('dzivokli.table_status')}</th>
            </tr>
          </thead>
          <tbody>
            {apartments.map((apt) => {
              const a = apt.data;
              const s = statusDict[a.status];
              const clickable = a.status === 'available';
              return (
                <tr
                  class:list={[
                    'apt-row border-t border-ink-muted/10 transition-colors',
                    clickable ? 'cursor-pointer hover:bg-beige/40' : 'opacity-70',
                  ]}
                  data-number={a.number}
                  data-floor={a.floor}
                  data-rooms={a.rooms}
                  data-terrace={a.has_terrace ? '1' : '0'}
                  data-balcony={a.has_balcony ? '1' : '0'}
                  data-status={a.status}
                  data-href={clickable ? aptDetailHref(a.number) : ''}
                >
                  <td class="px-5 py-4">
                    <span class="font-serif text-xl text-burgundy">{a.number}</span>
                  </td>
                  <td class="px-5 py-4 text-ink-muted">{a.floor}.</td>
                  <td class="px-5 py-4 text-ink">{a.rooms}</td>
                  <td class="px-5 py-4 text-ink tabular-nums">{a.area_total} m²</td>
                  <td class="px-5 py-4 text-ink tabular-nums">{formatPrice(a.price, lang)}</td>
                  <td class="px-5 py-4 text-ink-muted text-sm">{notesFor(a)}</td>
                  <td class="px-5 py-4 text-right pr-6">
                    <span class:list={['inline-flex items-center gap-2 rounded-full px-3 py-1 text-xs font-medium', s.bg, s.text]}>
                      <span class:list={['h-1.5 w-1.5 rounded-full', s.dot]} aria-hidden="true"></span>
                      {s.label}
                    </span>
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
        <p
          id="empty-state"
          class="hidden text-center py-10 text-ink-muted text-sm"
        >
          {t('dzivokli.empty')}
        </p>
      </div>

      <!-- Cards (mobile) -->
      <div class="md:hidden space-y-3">
        {apartments.map((apt) => {
          const a = apt.data;
          const s = statusDict[a.status];
          const clickable = a.status === 'available';
          return (
            <a
              href={clickable ? aptDetailHref(a.number) : '#'}
              class:list={[
                'apt-row block rounded-xl bg-cream border border-ink-muted/15 p-4',
                clickable ? 'hover:border-burgundy/30' : 'opacity-70 pointer-events-none',
              ]}
              data-number={a.number}
              data-floor={a.floor}
              data-rooms={a.rooms}
              data-terrace={a.has_terrace ? '1' : '0'}
              data-balcony={a.has_balcony ? '1' : '0'}
              data-status={a.status}
            >
              <div class="flex items-start justify-between gap-3">
                <div>
                  <span class="font-serif text-2xl text-burgundy">Nr. {a.number}</span>
                  <div class="mt-1 text-sm text-ink-muted">{floorLabel(a.floor)} · {a.rooms} {t('common.rooms_short')} · {a.area_total} m²</div>
                </div>
                <span class:list={['inline-flex items-center gap-2 rounded-full px-2.5 py-1 text-[11px] font-medium whitespace-nowrap', s.bg, s.text]}>
                  <span class:list={['h-1.5 w-1.5 rounded-full', s.dot]} aria-hidden="true"></span>
                  {s.label}
                </span>
              </div>
              <div class="mt-3 flex items-baseline justify-between gap-2">
                <span class="font-serif text-lg text-burgundy tabular-nums">{formatPrice(a.price, lang)}</span>
                <span class="text-xs text-ink-muted">{notesFor(a)}</span>
              </div>
            </a>
          );
        })}
      </div>
    </Container>
  </Section>

  <BottomCTA lang={lang} background="beige" />

  <!-- Floor-plan polygon tooltip — single shared element repositioned on hover. -->
  <div
    id="apt-tooltip"
    role="tooltip"
    aria-hidden="true"
    class="pointer-events-none fixed z-50 hidden rounded-xl border border-burgundy/15 bg-cream/95 backdrop-blur shadow-[0_12px_30px_-12px_rgba(90,31,42,0.35)] px-4 py-3 text-sm transition-opacity duration-100"
    style="opacity:0; transform: translate(-50%, calc(-100% - 12px));"
  >
    <div class="flex items-center gap-2">
      <span id="apt-tooltip-dot" class="h-2 w-2 rounded-full" aria-hidden="true"></span>
      <span id="apt-tooltip-status" class="text-[11px] uppercase tracking-[0.2em] text-ink-muted"></span>
    </div>
    <div class="mt-1.5 flex items-baseline gap-2">
      <span id="apt-tooltip-number" class="font-serif text-2xl text-burgundy"></span>
      <span id="apt-tooltip-meta" class="text-xs text-ink-muted tabular-nums"></span>
    </div>
    <div id="apt-tooltip-price" class="mt-1 font-serif text-lg text-burgundy tabular-nums"></div>
  </div>

  <style>
    @reference "@/styles/globals.css";
    .filter-chip {
      @apply inline-flex items-center justify-center min-w-[2.5rem] h-10 px-3 rounded-full bg-cream border border-ink-muted/20 text-sm text-ink cursor-pointer select-none transition-colors;
    }
    .filter-chip:hover { @apply border-burgundy/40; }
    .filter-chip:has(input:checked) { @apply bg-burgundy text-cream border-burgundy; }
    .apt-polygon { transition: fill-opacity 200ms; }
    .apt-polygon:hover,
    .apt-polygon.is-active { fill-opacity: 0.55 !important; }
  </style>

  <script>
    type FilterState = {
      floors: number[];
      rooms: number[];
      terrace: boolean;
      balcony: boolean;
      statuses: string[];
    };

    const form = document.getElementById('apt-filters') as HTMLFormElement;
    const rows = document.querySelectorAll<HTMLElement>('.apt-row');
    const counter = document.getElementById('filter-count')!;
    const empty = document.getElementById('empty-state');

    function readFilters(): FilterState {
      const fd = new FormData(form);
      return {
        floors:   fd.getAll('floor').map((v) => Number(v)),
        rooms:    fd.getAll('rooms').map((v) => Number(v)),
        terrace:  fd.has('terrace'),
        balcony:  fd.has('balcony'),
        statuses: fd.getAll('status').map(String),
      };
    }

    function apply() {
      const f = readFilters();
      const visibleNumbers = new Set<number>();
      rows.forEach((row) => {
        const num = Number(row.dataset.number);
        const floor = Number(row.dataset.floor);
        const rooms = Number(row.dataset.rooms);
        const terrace = row.dataset.terrace === '1';
        const balcony = row.dataset.balcony === '1';
        const status = row.dataset.status ?? '';
        const matches =
          (f.floors.length === 0 || f.floors.includes(floor)) &&
          (f.rooms.length === 0  || f.rooms.includes(rooms)) &&
          (!f.terrace || terrace) &&
          (!f.balcony || balcony) &&
          (f.statuses.length === 0 || f.statuses.includes(status));
        row.classList.toggle('hidden', !matches);
        if (matches) visibleNumbers.add(num);
      });
      counter.textContent = String(visibleNumbers.size);
      if (empty) empty.classList.toggle('hidden', visibleNumbers.size !== 0);
    }

    form.addEventListener('change', apply);
    form.addEventListener('reset', () => requestAnimationFrame(apply));

    document.querySelectorAll<HTMLElement>('tr.apt-row').forEach((row) => {
      const href = row.dataset.href;
      if (!href) return;
      row.addEventListener('click', () => { window.location.href = href; });
    });

    // Polygon hover tooltip — single shared element repositioned per pointer move.
    // We track an active polygon so moving between polygons hands off cleanly
    // without a race between a pending hide-timer and the next show.
    const tip       = document.getElementById('apt-tooltip')!;
    const tipDot    = document.getElementById('apt-tooltip-dot')!;
    const tipStatus = document.getElementById('apt-tooltip-status')!;
    const tipNumber = document.getElementById('apt-tooltip-number')!;
    const tipMeta   = document.getElementById('apt-tooltip-meta')!;
    const tipPrice  = document.getElementById('apt-tooltip-price')!;

    const dotByStatus: Record<string, string> = {
      available: 'bg-status-available',
      reserved:  'bg-status-reserved',
      sold:      'bg-status-sold',
    };

    let active: SVGPolygonElement | null = null;
    // Make sure the tooltip is participating in layout so transitions work.
    tip.classList.remove('hidden');
    tip.style.visibility = 'hidden';
    tip.style.opacity = '0';

    function populate(poly: SVGPolygonElement) {
      const d = poly.dataset;
      tipNumber.textContent = `Nr. ${d.number}`;
      tipMeta.textContent   = `${d.floorLabel} · ${d.rooms} ${d.roomsLabel} · ${d.area} m²`;
      tipPrice.textContent  = d.price ?? '';
      tipStatus.textContent = d.statusLabel ?? '';
      tipDot.className = `h-2 w-2 rounded-full ${dotByStatus[d.status ?? 'available']}`;
    }

    function showFor(poly: SVGPolygonElement, e: MouseEvent) {
      active = poly;
      populate(poly);
      tip.style.left = `${e.clientX}px`;
      tip.style.top  = `${e.clientY}px`;
      tip.style.visibility = 'visible';
      tip.style.opacity = '1';
      tip.setAttribute('aria-hidden', 'false');
    }

    function hideFor(poly: SVGPolygonElement) {
      // Only hide if leaving the polygon we're currently showing — protects
      // against an out-of-order mouseleave landing after we already showed
      // the tooltip for the next polygon.
      if (active !== poly) return;
      active = null;
      tip.style.opacity = '0';
      tip.style.visibility = 'hidden';
      tip.setAttribute('aria-hidden', 'true');
    }

    function moveTooltip(e: MouseEvent) {
      tip.style.left = `${e.clientX}px`;
      tip.style.top  = `${e.clientY}px`;
    }

    document.querySelectorAll<SVGPolygonElement>('polygon.apt-polygon').forEach((poly) => {
      // pointerenter/pointerleave fire reliably even when the cursor crosses
      // between sibling polygons in the same SVG (mouseenter/leave don't always).
      poly.addEventListener('pointerenter', (e) => showFor(poly, e as PointerEvent));
      poly.addEventListener('pointermove',  moveTooltip);
      poly.addEventListener('pointerleave', () => hideFor(poly));
    });

    const floorTabs = document.querySelectorAll<HTMLButtonElement>('.floor-tab');
    const floorPanels = document.querySelectorAll<HTMLElement>('[data-floor-panel]');
    floorTabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const floor = tab.dataset.floorTab;
        floorTabs.forEach((t) => {
          const isActive = t === tab;
          t.setAttribute('aria-selected', isActive ? 'true' : 'false');
          t.classList.toggle('bg-burgundy', isActive);
          t.classList.toggle('text-cream', isActive);
          t.classList.toggle('text-ink', !isActive);
        });
        floorPanels.forEach((p) => {
          p.classList.toggle('hidden', p.dataset.floorPanel !== floor);
        });
      });
    });

    apply();
  </script>
</BaseLayout>
