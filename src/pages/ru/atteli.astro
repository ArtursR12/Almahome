---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/ui/Container.astro';
import Section from '@/components/ui/Section.astro';
import BottomCTA from '@/components/layout/BottomCTA.astro';
import { getLocaleFromUrl, useTranslations, useTranslationsRaw } from '@/i18n/utils';

const lang = getLocaleFromUrl(Astro.url);
const t = useTranslations(lang);
const tr = useTranslationsRaw(lang);

interface GalleryItem { src: string; alt: string }

const exteriorSrcs = [
  '/images/exterior/exterior-summer.jpg',
  '/images/exterior/exterior-autumn.jpg',
  '/images/exterior/exterior-winter.jpg',
  '/images/exterior/alma_0000.jpg',
  '/images/exterior/alma_0003.jpg',
  '/images/exterior/alma_0006.jpg',
  '/images/exterior/000000056050505_alma_0003.jpg',
];
const interiorSrcs = [
  '/images/renders/alma_kitchen_final.jpg',
  '/images/renders/alma_livingroom_final.jpg',
  '/images/renders/alma_bedroom1-final.jpg',
  '/images/renders/alma_bedroom2-final.jpg',
  '/images/renders/0001alma_bedroom2-final.jpg',
  '/images/renders/alma_dz16-living1-final.jpg',
  '/images/renders/alma_dz16-living1-final-2.jpg',
  '/images/renders/alma_dz16-living2_final.jpg',
  '/images/renders/alma_dz16-living3-final.jpg',
  '/images/renders/alma_kidsroom-final.jpg',
  '/images/renders/alma_wc-final.jpg',
  '/images/renders/0000002alma_wc-final.jpg',
];

const exteriorAlts = tr<string[]>('atteli.exterior_alts');
const interiorAlts = tr<string[]>('atteli.interior_alts');

const exterior: GalleryItem[] = exteriorSrcs.map((src, i) => ({ src, alt: exteriorAlts[i] ?? src }));
const interior: GalleryItem[] = interiorSrcs.map((src, i) => ({ src, alt: interiorAlts[i] ?? src }));

const tabs = [
  { id: 'exterior', label: t('atteli.tab_exterior'), items: exterior },
  { id: 'interior', label: t('atteli.tab_interior'), items: interior },
];
---
<BaseLayout
  lang={lang}
  title={t('atteli.title')}
  description={t('atteli.description')}
>
  <Section background="cream">
    <Container>
      <div class="text-center mb-10">
        <p class="text-xs uppercase tracking-[0.3em] text-ink-muted">{t('atteli.hero_kicker')}</p>
        <h1 class="mt-4 font-serif text-5xl md:text-6xl text-burgundy">{t('atteli.hero_title')}</h1>
        <p class="mt-4 text-ink-muted max-w-2xl mx-auto">
          {t('atteli.hero_subtitle')}
        </p>
      </div>

      <!-- Tabs -->
      <div role="tablist" class="flex flex-wrap justify-center gap-2 mb-10">
        {tabs.map((tab, i) => (
          <button
            type="button"
            role="tab"
            data-tab-target={tab.id}
            aria-selected={i === 0 ? 'true' : 'false'}
            class:list={[
              'px-5 py-2.5 rounded-full text-sm font-medium transition-colors',
              'gallery-tab-btn',
              i === 0 ? 'bg-burgundy text-cream' : 'bg-beige text-ink hover:bg-burgundy/10',
            ]}
          >
            {tab.label} <span class="opacity-60 ml-1">({tab.items.length})</span>
          </button>
        ))}
      </div>

      <!-- Tab panels -->
      {tabs.map((tab, i) => (
        <div
          id={`gallery-${tab.id}`}
          role="tabpanel"
          class:list={['gallery-panel grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3 md:gap-4', i === 0 ? '' : 'hidden']}
        >
          {tab.items.map((item, idx) => (
            <button
              type="button"
              class="gallery-item group relative overflow-hidden rounded-lg bg-beige aspect-[4/3] cursor-zoom-in"
              data-gallery={tab.id}
              data-index={idx}
              data-src={item.src}
              data-alt={item.alt}
            >
              <img
                src={item.src}
                alt={item.alt}
                loading="lazy"
                class="absolute inset-0 h-full w-full object-cover transition-transform duration-300 group-hover:scale-[1.04]"
              />
              <span class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-burgundy-dark/70 to-transparent p-3 text-left text-xs text-cream/95 opacity-0 group-hover:opacity-100 transition-opacity">
                {item.alt}
              </span>
            </button>
          ))}
        </div>
      ))}
    </Container>
  </Section>

  <!-- Lightbox overlay -->
  <div
    id="lightbox"
    class="fixed inset-0 z-50 hidden items-center justify-center bg-burgundy-dark/90 backdrop-blur-sm"
    aria-hidden="true"
    role="dialog"
    aria-modal="true"
  >
    <button
      type="button"
      id="lightbox-close"
      aria-label={t('atteli.lightbox_close')}
      class="absolute top-4 right-4 h-12 w-12 rounded-full bg-cream/10 hover:bg-cream/20 text-cream flex items-center justify-center transition-colors"
    >
      <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 6l12 12M18 6L6 18" stroke-linecap="round"/></svg>
    </button>
    <button
      type="button"
      id="lightbox-prev"
      aria-label={t('atteli.lightbox_prev')}
      class="absolute left-4 top-1/2 -translate-y-1/2 h-12 w-12 rounded-full bg-cream/10 hover:bg-cream/20 text-cream flex items-center justify-center transition-colors"
    >
      <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 18l-6-6 6-6" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </button>
    <button
      type="button"
      id="lightbox-next"
      aria-label={t('atteli.lightbox_next')}
      class="absolute right-4 top-1/2 -translate-y-1/2 h-12 w-12 rounded-full bg-cream/10 hover:bg-cream/20 text-cream flex items-center justify-center transition-colors"
    >
      <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </button>

    <figure class="max-w-[92vw] max-h-[88vh] flex flex-col items-center gap-3">
      <img id="lightbox-img" src="" alt="" class="max-h-[80vh] max-w-[92vw] object-contain rounded-md shadow-2xl" />
      <figcaption id="lightbox-caption" class="text-cream/85 text-sm text-center"></figcaption>
    </figure>
  </div>

  <script>
    type Item = { src: string; alt: string };

    const tabs = document.querySelectorAll<HTMLButtonElement>('.gallery-tab-btn');
    const panels = document.querySelectorAll<HTMLElement>('.gallery-panel');

    tabs.forEach((btn) => {
      btn.addEventListener('click', () => {
        const target = btn.getAttribute('data-tab-target');
        tabs.forEach((b) => {
          const active = b === btn;
          b.setAttribute('aria-selected', active ? 'true' : 'false');
          b.classList.toggle('bg-burgundy', active);
          b.classList.toggle('text-cream', active);
          b.classList.toggle('bg-beige', !active);
          b.classList.toggle('text-ink', !active);
        });
        panels.forEach((p) => {
          p.classList.toggle('hidden', p.id !== `gallery-${target}`);
        });
      });
    });

    const overlay = document.getElementById('lightbox')!;
    const overlayImg = document.getElementById('lightbox-img') as HTMLImageElement;
    const overlayCaption = document.getElementById('lightbox-caption')!;
    const btnClose = document.getElementById('lightbox-close')!;
    const btnPrev = document.getElementById('lightbox-prev')!;
    const btnNext = document.getElementById('lightbox-next')!;

    let activeList: Item[] = [];
    let activeIndex = 0;

    function openLightbox(list: Item[], index: number) {
      activeList = list;
      activeIndex = index;
      render();
      overlay.classList.remove('hidden');
      overlay.classList.add('flex');
      overlay.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    }

    function closeLightbox() {
      overlay.classList.add('hidden');
      overlay.classList.remove('flex');
      overlay.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    }

    function step(delta: number) {
      if (!activeList.length) return;
      activeIndex = (activeIndex + delta + activeList.length) % activeList.length;
      render();
    }

    function render() {
      const item = activeList[activeIndex];
      if (!item) return;
      overlayImg.src = item.src;
      overlayImg.alt = item.alt;
      overlayCaption.textContent = `${item.alt} · ${activeIndex + 1} / ${activeList.length}`;
    }

    document.querySelectorAll<HTMLButtonElement>('.gallery-item').forEach((btn) => {
      btn.addEventListener('click', () => {
        const galleryId = btn.getAttribute('data-gallery');
        const list = Array.from(
          document.querySelectorAll<HTMLButtonElement>(`.gallery-item[data-gallery="${galleryId}"]`),
        ).map((el) => ({
          src: el.getAttribute('data-src') ?? '',
          alt: el.getAttribute('data-alt') ?? '',
        }));
        const idx = parseInt(btn.getAttribute('data-index') ?? '0', 10);
        openLightbox(list, idx);
      });
    });

    btnClose.addEventListener('click', closeLightbox);
    btnPrev.addEventListener('click', (e) => { e.stopPropagation(); step(-1); });
    btnNext.addEventListener('click', (e) => { e.stopPropagation(); step(1); });
    overlay.addEventListener('click', (e) => {
      if (e.target === overlay) closeLightbox();
    });
    document.addEventListener('keydown', (e) => {
      if (overlay.classList.contains('hidden')) return;
      if (e.key === 'Escape') closeLightbox();
      if (e.key === 'ArrowLeft') step(-1);
      if (e.key === 'ArrowRight') step(1);
    });
  </script>

  <BottomCTA lang={lang} background="beige" />
</BaseLayout>
