---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/ui/Container.astro';
import Section from '@/components/ui/Section.astro';
import Button from '@/components/ui/Button.astro';
import PhotoOrPlaceholder from '@/components/ui/PhotoOrPlaceholder.astro';
import { getLocaleFromUrl, useTranslations, useTranslationsRaw, getLocalizedUrl } from '@/i18n/utils';

const lang = getLocaleFromUrl(Astro.url);
const t = useTranslations(lang);
const tr = useTranslationsRaw(lang);

const stats     = tr<{ value: string; label: string }[]>('par_projektu.stats');
const landmarks = tr<{ time: string; name: string; note: string }[]>('par_projektu.landmarks');
---
<BaseLayout
  lang={lang}
  title={t('par_projektu.title')}
  description={t('par_projektu.description')}
>
  <!-- Hero -->
  <section class="relative min-h-[60vh] flex items-center overflow-hidden py-24 md:py-32">
    <PhotoOrPlaceholder
      src="/images/exterior/exterior-winter.jpg"
      width={1920}
      height={1080}
      alt={t('par_projektu.hero_title')}
      label={t('par_projektu.hero_title')}
      loading="eager"
      class="absolute inset-0 h-full w-full object-cover"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/70 via-black/55 to-black/70"></div>
    <Container class="relative text-center text-cream">
      <div class="flex flex-col items-center space-y-7">
        <p class="text-[11px] md:text-xs uppercase tracking-[0.5em] text-cream/70">{t('par_projektu.hero_kicker')}</p>
        <h1 class="font-serif text-5xl md:text-7xl leading-[1.05]">{t('par_projektu.hero_title')}</h1>
        <p class="max-w-xl text-base md:text-lg text-cream/85 leading-relaxed">
          {t('par_projektu.hero_subtitle')}
        </p>
      </div>
    </Container>
  </section>

  <!-- Stats -->
  <Section background="cream" class="!py-16">
    <Container>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-12">
        {stats.map((s) => (
          <div class="text-center">
            <div class="font-serif text-5xl md:text-6xl text-burgundy">{s.value}</div>
            <div class="mt-2 text-sm uppercase tracking-widest text-ink-muted">{s.label}</div>
          </div>
        ))}
      </div>
    </Container>
  </Section>

  <!-- Project overview -->
  <Section background="beige">
    <Container>
      <div class="grid md:grid-cols-2 gap-12 lg:gap-20 items-center">
        <div>
          <p class="text-xs uppercase tracking-[0.3em] text-ink-muted">{t('par_projektu.overview_kicker')}</p>
          <h2 class="mt-4 font-serif text-4xl md:text-5xl text-burgundy leading-tight">
            {t('par_projektu.overview_title')}
          </h2>
          <p class="mt-6 text-lg text-ink-muted leading-relaxed">
            {t('par_projektu.overview_body_1')}
          </p>
          <p class="mt-4 text-lg text-ink-muted leading-relaxed">
            {t('par_projektu.overview_body_2')}
          </p>
          <div class="mt-8">
            <Button variant="secondary" href={getLocalizedUrl('/dzivokli', lang)}>{t('home.cta_view_all_apartments')}</Button>
          </div>
        </div>
        <div>
          <PhotoOrPlaceholder
            src="/images/exterior/3stavs.jpg"
            width={800}
            height={600}
            alt={t('par_projektu.overview_title')}
            label={t('par_projektu.overview_title')}
            rounded
            class="w-full h-auto object-cover aspect-[4/3]"
          />
        </div>
      </div>
    </Container>
  </Section>

  <!-- Map -->
  <Section background="cream">
    <Container>
      <div class="text-center mb-12">
        <p class="text-xs uppercase tracking-[0.3em] text-ink-muted">{t('par_projektu.map_kicker')}</p>
        <h2 class="mt-4 font-serif text-4xl md:text-5xl text-burgundy">{t('par_projektu.map_title')}</h2>
        <p class="mt-4 text-ink-muted max-w-2xl mx-auto">
          {t('par_projektu.map_body')}
        </p>
      </div>

      <a
        href="https://www.google.com/maps/search/?api=1&query=Mores+iela+15%2C+Riga%2C+Latvia"
        target="_blank"
        rel="noopener"
        class="group block rounded-xl overflow-hidden bg-beige aspect-[16/9] md:aspect-[21/9] relative"
        aria-label={t('common.open_google_maps')}
      >
        <img
          src="/images/maps/almahome-map.jpg"
          alt={t('par_projektu.map_title')}
          loading="lazy"
          width={1600}
          height={700}
          class="absolute inset-0 h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.02]"
        />
        <span class="absolute bottom-4 right-4 inline-flex items-center gap-2 rounded-full bg-cream/95 backdrop-blur px-4 py-2 text-sm text-burgundy shadow-md">
          {t('common.open_google_maps')}
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M17 7H9M17 7v8" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </span>
      </a>
    </Container>
  </Section>

  <!-- Landmarks -->
  <Section background="beige">
    <Container>
      <div class="text-center mb-12">
        <p class="text-xs uppercase tracking-[0.3em] text-ink-muted">{t('par_projektu.landmarks_kicker')}</p>
        <h2 class="mt-4 font-serif text-4xl md:text-5xl text-burgundy">{t('par_projektu.landmarks_title')}</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        {landmarks.map((l) => (
          <div class="bg-cream rounded-xl p-6 flex items-start gap-5 border border-burgundy/5">
            <span class="font-serif text-3xl text-burgundy whitespace-nowrap leading-none pt-1 shrink-0">{l.time}</span>
            <div class="min-w-0">
              <div class="text-base font-medium text-ink leading-tight">{l.name}</div>
              <div class="mt-1 text-sm text-ink-muted leading-snug">{l.note}</div>
            </div>
          </div>
        ))}
      </div>
    </Container>
  </Section>

  <!-- CTA -->
  <Section background="cream" class="!py-16">
    <Container class="text-center">
      <h2 class="font-serif text-3xl md:text-4xl text-burgundy">
        {t('par_projektu.cta_title')}
      </h2>
      <p class="mt-4 text-ink-muted max-w-xl mx-auto">
        {t('par_projektu.cta_body')}
      </p>
      <div class="mt-8 flex flex-col sm:flex-row gap-3 justify-center">
        <Button variant="primary" size="lg" href={getLocalizedUrl('/dzivokli', lang)}>{t('home.cta_view_apartments')}</Button>
        <Button variant="secondary" size="lg" href={getLocalizedUrl('/kontakti', lang)}>{t('home.cta_contact')}</Button>
      </div>
    </Container>
  </Section>
</BaseLayout>
