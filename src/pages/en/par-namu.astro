---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/ui/Container.astro';
import Section from '@/components/ui/Section.astro';
import PhotoOrPlaceholder from '@/components/ui/PhotoOrPlaceholder.astro';
import BottomCTA from '@/components/layout/BottomCTA.astro';
import SectionKicker from '@/components/ui/SectionKicker.astro';
import { getLocaleFromUrl, useTranslations, useTranslationsRaw } from '@/i18n/utils';

const lang = getLocaleFromUrl(Astro.url);
const t = useTranslations(lang);
const tr = useTranslationsRaw(lang);

const materialCards = tr<{ title: string; desc: string }[]>('par_namu.materials_cards');
const energyFeatures = tr<string[]>('par_namu.energy_features');

const cardImages = [
  '/images/_misc/2026__03__22__gridas001.jpg',
  '/images/_misc/2026__03__25__durvi.jpg',
  '/images/_misc/2026__03__25__kuhnja_0002.jpg',
  '/images/_misc/2026__03__25__santeh1.jpg',
];
---
<BaseLayout
  lang={lang}
  title={t('par_namu.title')}
  description={t('par_namu.description')}
>
  <!-- Hero -->
  <section class="relative min-h-[60vh] flex items-center overflow-hidden py-24 md:py-32">
    <PhotoOrPlaceholder
      src="/images/exterior/exterior-summer.jpg"
      width={1920}
      height={1080}
      alt={t('par_namu.hero_title')}
      label={t('par_namu.hero_title')}
      loading="eager"
      class="absolute inset-0 h-full w-full object-cover"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/70 via-black/55 to-black/70"></div>
    <Container class="relative text-center text-cream">
      <div class="flex flex-col items-center space-y-7">
        <p class="text-[11px] md:text-xs uppercase tracking-[0.5em] text-cream/70">{t('par_namu.hero_kicker')}</p>
        <h1 class="font-serif text-5xl md:text-7xl leading-[1.05]">{t('par_namu.hero_title')}</h1>
        <p class="max-w-xl text-base md:text-lg text-cream/85 leading-relaxed">
          {t('par_namu.hero_subtitle')}
        </p>
      </div>
    </Container>
  </section>

  <!-- Architecture -->
  <Section background="cream">
    <Container>
      <div class="grid md:grid-cols-2 gap-12 lg:gap-20 items-center">
        <div>
          <SectionKicker index={1}>{t('par_namu.arch_kicker')}</SectionKicker>
          <h2 class="mt-5 font-serif text-4xl md:text-5xl text-burgundy leading-tight">
            {t('par_namu.arch_title')}
          </h2>
          <p class="mt-6 text-lg text-ink-muted leading-relaxed">{t('par_namu.arch_body_1')}</p>
          <p class="mt-4 text-lg text-ink-muted leading-relaxed">{t('par_namu.arch_body_2')}</p>
        </div>
        <div>
          <PhotoOrPlaceholder
            src="/images/exterior/alma_0006.jpg"
            width={800}
            height={600}
            alt={t('par_namu.arch_title')}
            label={t('par_namu.arch_title')}
            rounded
            class="w-full h-auto object-cover aspect-[4/3]"
          />
        </div>
      </div>
    </Container>
  </Section>

  <!-- Materials -->
  <Section background="beige">
    <Container>
      <div class="flex flex-col items-center text-center mb-12">
        <SectionKicker index={2} align="center">{t('par_namu.materials_kicker')}</SectionKicker>
        <h2 class="mt-5 font-serif text-4xl md:text-5xl text-burgundy">{t('par_namu.materials_title')}</h2>
        <p class="mt-4 text-ink-muted max-w-2xl">
          {t('par_namu.materials_body')}
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5 md:gap-6">
        {materialCards.map((m, i) => (
          <article class="group bg-cream rounded-2xl overflow-hidden flex flex-col border border-burgundy/5 transition-all duration-300 hover:-translate-y-0.5 hover:shadow-[0_24px_60px_-30px_rgba(90,31,42,0.35)]">
            <div class="relative aspect-[4/3] overflow-hidden bg-gradient-to-br from-cream via-beige/60 to-beige flex items-center justify-center">
              <span class="absolute top-3 left-3 text-[10px] uppercase tracking-[0.3em] text-burgundy/50 font-medium">{String(i + 1).padStart(2, '0')}</span>
              <PhotoOrPlaceholder
                src={cardImages[i]}
                width={400}
                height={300}
                alt={m.title}
                label={m.title}
                class="max-h-[78%] max-w-[78%] object-contain transition-transform duration-300 group-hover:scale-[1.04]"
              />
            </div>
            <div class="p-6 flex flex-col flex-1 min-h-[180px]">
              <h3 class="font-serif text-2xl text-burgundy leading-tight">{m.title}</h3>
              <p class="mt-3 text-sm text-ink-muted leading-relaxed flex-1">{m.desc}</p>
            </div>
          </article>
        ))}
      </div>
    </Container>
  </Section>

  <!-- Energy -->
  <Section background="cream">
    <Container>
      <div class="grid md:grid-cols-2 gap-12 lg:gap-20 items-center">
        <div class="md:order-2">
          <SectionKicker index={3}>{t('par_namu.energy_kicker')}</SectionKicker>
          <h2 class="mt-5 font-serif text-4xl md:text-5xl text-burgundy leading-tight">
            {t('par_namu.energy_title')}
          </h2>
          <p class="mt-6 text-lg text-ink-muted leading-relaxed">
            {t('par_namu.energy_body')}
          </p>
          <ul class="mt-8 space-y-4 text-base text-ink">
            {energyFeatures.map((f, i) => (
              <li class="flex items-start gap-4">
                <span class="font-serif text-sm text-burgundy/70 shrink-0 mt-1 tracking-wider tabular-nums">0{i + 1}</span>
                <span class="leading-relaxed">{f}</span>
              </li>
            ))}
          </ul>
        </div>
        <div class="md:order-1">
          <PhotoOrPlaceholder
            src="/images/renders/render-kitchen-dining.jpg"
            width={800}
            height={600}
            alt={t('par_namu.energy_title')}
            label={t('par_namu.energy_title')}
            rounded
            class="w-full h-auto object-cover aspect-[4/3]"
          />
        </div>
      </div>
    </Container>
  </Section>

  <!-- Surroundings -->
  <Section background="beige">
    <Container>
      <div class="grid md:grid-cols-2 gap-12 lg:gap-20 items-center">
        <div>
          <SectionKicker index={4}>{t('par_namu.surroundings_kicker')}</SectionKicker>
          <h2 class="mt-5 font-serif text-4xl md:text-5xl text-burgundy leading-tight">
            {t('par_namu.surroundings_title')}
          </h2>
          <p class="mt-6 text-lg text-ink-muted leading-relaxed">
            {t('par_namu.surroundings_body_1')}
          </p>
          <p class="mt-4 text-lg text-ink-muted leading-relaxed">
            {t('par_namu.surroundings_body_2')}
          </p>
        </div>
        <div>
          <PhotoOrPlaceholder
            src="/images/exterior/exterior-autumn.jpg"
            width={800}
            height={600}
            alt={t('par_namu.surroundings_title')}
            label={t('par_namu.surroundings_title')}
            rounded
            class="w-full h-auto object-cover aspect-[4/3]"
          />
        </div>
      </div>
    </Container>
  </Section>

  <BottomCTA lang={lang} background="cream" />
</BaseLayout>
