---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/ui/Container.astro';
import Section from '@/components/ui/Section.astro';
import PhotoOrPlaceholder from '@/components/ui/PhotoOrPlaceholder.astro';
import ContactForm from '@/components/forms/ContactForm.svelte';
import SectionKicker from '@/components/ui/SectionKicker.astro';
import { partnerBanks } from '@/data/partner-banks';
import { getLocaleFromUrl, useTranslations } from '@/i18n/utils';

const lang = getLocaleFromUrl(Astro.url);
const t = useTranslations(lang);
---
<BaseLayout
  lang={lang}
  title={t('kontakti.title')}
  description={t('kontakti.description')}
>
  <Section background="cream">
    <Container>
      <div class="flex flex-col items-center text-center mb-12">
        <SectionKicker align="center">{t('kontakti.hero_kicker')}</SectionKicker>
        <h1 class="mt-5 font-serif text-5xl md:text-6xl text-burgundy">{t('kontakti.hero_title')}</h1>
        <p class="mt-4 text-ink-muted max-w-2xl">
          {t('kontakti.hero_subtitle')}
        </p>
      </div>

      <div class="grid lg:grid-cols-5 gap-12">
        <!-- Form -->
        <div class="lg:col-span-3 bg-beige rounded-xl p-6 md:p-10">
          <h2 class="font-serif text-2xl text-burgundy mb-6">{t('form.title')}</h2>
          <ContactForm client:load lang={lang} />
        </div>

        <!-- Contact info -->
        <aside class="lg:col-span-2 space-y-5">
          <div class="rounded-xl bg-beige p-6 md:p-8">
            <h3 class="font-serif text-xl text-burgundy">{t('kontakti.address_label')}</h3>
            <address class="not-italic mt-3 text-lg text-ink leading-relaxed">
              Mores iela 15<br />Rīga, LV-1034<br />Latvija
            </address>
          </div>
          <div class="rounded-xl bg-beige p-6 md:p-8">
            <h3 class="font-serif text-xl text-burgundy">{t('kontakti.phone_label')}</h3>
            <p class="mt-3 text-lg">
              <a href={`tel:${t('site.phone_compact')}`} class="text-ink hover:text-burgundy transition-colors">{t('site.phone')}</a>
            </p>
            <p class="mt-1 text-sm text-ink-muted">{t('kontakti.phone_hours')}</p>
          </div>
          <div class="rounded-xl bg-beige p-6 md:p-8">
            <h3 class="font-serif text-xl text-burgundy">{t('kontakti.email_label')}</h3>
            <p class="mt-3 text-lg">
              <a href={`mailto:${t('site.email')}`} class="text-ink hover:text-burgundy transition-colors">{t('site.email')}</a>
            </p>
          </div>
        </aside>
      </div>
    </Container>
  </Section>

  <!-- Map -->
  <Section background="beige" class="!py-16">
    <Container>
      <div class="flex flex-col items-center text-center mb-8">
        <SectionKicker align="center">{t('kontakti.map_kicker')}</SectionKicker>
        <h2 class="mt-4 font-serif text-3xl md:text-4xl text-burgundy">{t('kontakti.map_title')}</h2>
      </div>
      <a
        href="https://www.google.com/maps/search/?api=1&query=Mores+iela+15%2C+Riga%2C+Latvia"
        target="_blank"
        rel="noopener"
        class="group block rounded-xl overflow-hidden bg-cream aspect-[16/9] md:aspect-[21/9] relative"
        aria-label={t('common.open_google_maps')}
      >
        <img
          src="/images/maps/almahome-map.jpg"
          alt={t('kontakti.map_title')}
          loading="lazy"
          width={1600}
          height={700}
          class="absolute inset-0 h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.02]"
        />
        <span class="absolute bottom-4 right-4 inline-flex items-center gap-2 rounded-full bg-cream/95 backdrop-blur px-4 py-2 text-sm text-burgundy shadow-md">
          {t('common.open_google_maps')}
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M17 7H9M17 7v8" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </span>
      </a>
    </Container>
  </Section>

  <!-- Bank partners -->
  <Section background="cream" class="!py-16">
    <Container>
      <div class="flex flex-col items-center text-center mb-10">
        <SectionKicker align="center">{t('kontakti.banks_kicker')}</SectionKicker>
        <h2 class="mt-4 font-serif text-3xl md:text-4xl text-burgundy">
          {t('kontakti.banks_title')}
        </h2>
      </div>
      <div class="mx-auto max-w-5xl grid grid-cols-2 gap-y-10 gap-x-12 items-center md:flex md:justify-between md:gap-12">
        {partnerBanks.map((bank) => (
          <a
            href={bank.url}
            target="_blank"
            rel="noopener nofollow"
            aria-label={bank.name}
            class="block mx-auto max-w-[140px]"
          >
            <PhotoOrPlaceholder
              src={bank.logo}
              width={160}
              height={48}
              alt={bank.name}
              label={bank.name}
              class="object-contain h-10 md:h-12 w-auto opacity-60 hover:opacity-100 transition-opacity duration-200"
            />
          </a>
        ))}
      </div>
    </Container>
  </Section>
</BaseLayout>
