---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/ui/Container.astro';
import Section from '@/components/ui/Section.astro';
import SectionKicker from '@/components/ui/SectionKicker.astro';
import { getLocaleFromUrl, useTranslations } from '@/i18n/utils';

const lang = getLocaleFromUrl(Astro.url);
const t = useTranslations(lang);

// === BEFORE PUBLISHING: fill in the {{ ... }} placeholders and the LAST_UPDATED date. ===
// The same TODOs exist in /privatums.astro and /ru/privatums.astro — fill all three.
const LAST_UPDATED = '2026-05-11';
---
<BaseLayout
  lang={lang}
  title={t('privatums.title')}
  description={t('privatums.description')}
>
  <section class="bg-burgundy text-cream">
    <Container class="py-20 md:py-28">
      <div class="max-w-3xl">
        <p class="text-xs uppercase tracking-[0.4em] text-cream/70">{t('privatums.hero_kicker')}</p>
        <h1 class="mt-5 font-serif text-5xl md:text-6xl leading-[1.05]">{t('privatums.hero_title')}</h1>
        <p class="mt-6 text-sm text-cream/70">
          {t('privatums.updated_label')}: <time datetime={LAST_UPDATED}>{LAST_UPDATED}</time>
        </p>
      </div>
    </Container>
  </section>

  <Section background="cream">
    <Container>
      <article class="prose-policy max-w-3xl mx-auto space-y-12 text-ink leading-relaxed">

        <div>
          <SectionKicker index={1}>1. Data controller</SectionKicker>
          <h2 class="mt-4 font-serif text-2xl md:text-3xl text-burgundy">Who processes your data</h2>
          <p class="mt-4">
            Personal data submitted through almahome.lv is processed by:
          </p>
          <ul class="mt-3 space-y-1.5">
            <li>Name: <mark class="todo">{`{{ SIA "ALMA HOME" or full legal name }}`}</mark></li>
            <li>Registration number: <mark class="todo">{`{{ XXXXXXXXXXX }}`}</mark></li>
            <li>Legal address: <mark class="todo">{`{{ Address, Rīga, LV-XXXX }}`}</mark></li>
            <li>Email: <a href="mailto:info@almahome.lv">info@almahome.lv</a></li>
            <li>Phone: <a href="tel:+37126148011">+371 26 148 011</a></li>
          </ul>
        </div>

        <div>
          <SectionKicker index={2}>2. Data categories</SectionKicker>
          <h2 class="mt-4 font-serif text-2xl md:text-3xl text-burgundy">What data we collect</h2>
          <p class="mt-4">
            We only collect data that you voluntarily provide through the inquiry form on this site:
          </p>
          <ul class="mt-3 space-y-1.5">
            <li>name;</li>
            <li>email address;</li>
            <li>phone number;</li>
            <li>your message (if provided);</li>
            <li>the apartment number you are inquiring about (when the form is submitted from a specific apartment page).</li>
          </ul>
          <p class="mt-4">
            We do <strong>not</strong> collect payment data, identification documents, banking details, or any other particularly protected data. We do not use advertising or analytics tracking cookies.
          </p>
        </div>

        <div>
          <SectionKicker index={3}>3. Legal basis</SectionKicker>
          <h2 class="mt-4 font-serif text-2xl md:text-3xl text-burgundy">Why and on what basis we process the data</h2>
          <p class="mt-4">Personal data is processed solely to:</p>
          <ul class="mt-3 space-y-1.5">
            <li>respond to your inquiries regarding apartment sales and project details;</li>
            <li>continue communication during the sales process;</li>
            <li>if applicable, prepare a reservation or purchase agreement for an apartment.</li>
          </ul>
          <p class="mt-4">
            Legal basis — <strong>Article 6(1)</strong> of the EU General Data Protection Regulation (GDPR):
          </p>
          <ul class="mt-3 space-y-1.5">
            <li><strong>(b)</strong> — processing is necessary to take steps at your request prior to entering into a contract;</li>
            <li><strong>(f)</strong> — legitimate interest in maintaining communication with prospective customers.</li>
          </ul>
        </div>

        <div>
          <SectionKicker index={4}>4. Recipients</SectionKicker>
          <h2 class="mt-4 font-serif text-2xl md:text-3xl text-burgundy">Who data may be shared with</h2>
          <p class="mt-4">
            To run this site and receive your inquiries we use the following technical service providers as data processors:
          </p>
          <ul class="mt-3 space-y-1.5">
            <li><strong>Vercel Inc.</strong> (USA) — site hosting. Privacy policy: <a href="https://vercel.com/legal/privacy-policy" target="_blank" rel="noopener">vercel.com/legal/privacy-policy</a>.</li>
            <li><strong>Resend, Inc.</strong> (USA) — email delivery (your inquiry is forwarded to info@almahome.lv). Privacy policy: <a href="https://resend.com/legal/privacy-policy" target="_blank" rel="noopener">resend.com/legal/privacy-policy</a>.</li>
            <li><strong>GitHub, Inc.</strong> (USA) — source code and content repository for the site.</li>
          </ul>
          <p class="mt-4">
            These providers process data under the European Commission's Standard Contractual Clauses (SCC). We do <strong>not</strong> share your data with marketing companies or third parties for advertising or commercial purposes.
          </p>
          <p class="mt-4">
            If you choose to apply for a mortgage with one of our partner banks (Bigbank, Citadele, Luminor, Swedbank, SEB), you contact the bank directly — we do not share your data with the bank.
          </p>
        </div>

        <div>
          <SectionKicker index={5}>5. Retention</SectionKicker>
          <h2 class="mt-4 font-serif text-2xl md:text-3xl text-burgundy">How long we keep the data</h2>
          <ul class="mt-4 space-y-1.5">
            <li>For the duration of active communication and for <mark class="todo">{'{{ 12 months }}'}</mark> after the last contact, unless a longer period is required by law.</li>
            <li>If a purchase agreement is concluded — in accordance with Latvian accounting and tax laws (typically 5–10 years).</li>
          </ul>
          <p class="mt-4">
            After the retention period, data is deleted or fully anonymized.
          </p>
        </div>

        <div>
          <SectionKicker index={6}>6. Cookies</SectionKicker>
          <h2 class="mt-4 font-serif text-2xl md:text-3xl text-burgundy">Cookies and tracking</h2>
          <p class="mt-4">
            The almahome.lv site does <strong>not</strong> use advertising trackers, analytics (e.g. Google Analytics), or third-party marketing cookies. Only strictly necessary cookies are used to provide basic site functionality (e.g. remembering your selected language).
          </p>
        </div>

        <div>
          <SectionKicker index={7}>7. Your rights</SectionKicker>
          <h2 class="mt-4 font-serif text-2xl md:text-3xl text-burgundy">Your rights under GDPR</h2>
          <p class="mt-4">You have the right to:</p>
          <ul class="mt-3 space-y-1.5">
            <li>request access to your personal data and obtain a copy;</li>
            <li>request rectification of inaccurate data;</li>
            <li>request erasure of data ("right to be forgotten");</li>
            <li>request restriction of processing or object to processing;</li>
            <li>request data portability;</li>
            <li>withdraw previously given consent;</li>
            <li>lodge a complaint with the supervisory authority — <a href="https://www.dvi.gov.lv" target="_blank" rel="noopener"><strong>Data State Inspectorate of Latvia</strong></a> (www.dvi.gov.lv).</li>
          </ul>
          <p class="mt-4">
            To exercise these rights, please write to <a href="mailto:info@almahome.lv">info@almahome.lv</a>. We will respond within one month.
          </p>
        </div>

        <div>
          <SectionKicker index={8}>8. Contact</SectionKicker>
          <h2 class="mt-4 font-serif text-2xl md:text-3xl text-burgundy">Privacy questions</h2>
          <p class="mt-4">
            For any questions regarding the processing of personal data on this site, please contact:
          </p>
          <ul class="mt-3 space-y-1.5">
            <li>Email: <a href="mailto:info@almahome.lv">info@almahome.lv</a></li>
            <li>Phone: <a href="tel:+37126148011">+371 26 148 011</a></li>
            <li>Address: Mores iela 15, Rīga, LV-1034</li>
          </ul>
        </div>

        <div>
          <SectionKicker index={9}>9. Updates</SectionKicker>
          <h2 class="mt-4 font-serif text-2xl md:text-3xl text-burgundy">Policy updates</h2>
          <p class="mt-4">
            This privacy policy may be updated to reflect changes in legislation or our practices. The last update date is shown at the top of the document. We will announce material changes on this page.
          </p>
        </div>

      </article>
    </Container>
  </Section>
</BaseLayout>

<style>
  @reference "@/styles/globals.css";
  .prose-policy .todo {
    @apply bg-status-reserved/35 text-ink px-1.5 py-0.5 rounded font-mono text-[0.92em];
  }
  .prose-policy a {
    @apply text-burgundy underline underline-offset-4 decoration-burgundy/40 hover:decoration-burgundy transition-colors;
  }
  .prose-policy ul {
    @apply list-disc pl-6 text-ink;
  }
  .prose-policy strong {
    @apply text-ink font-semibold;
  }
  .prose-policy p {
    @apply text-ink;
  }
</style>
