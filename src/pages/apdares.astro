---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/ui/Container.astro';
import Section from '@/components/ui/Section.astro';
import Button from '@/components/ui/Button.astro';

interface Row {
  name?: string;
  description: string;
  provider?: string;
  notes?: string;
  image?: string;
  imageAlt?: string;
}

interface Group {
  title: string;
  rows: Row[];
}

const groups: Group[] = [
  {
    title: 'Sienas',
    rows: [
      {
        name: 'Pamati un cokols',
        description:
          'Lentveida betona pamati, uz kuriem novietotas no keramzītbetona blokiem būvējamas sienas.',
        provider: 'Jā',
      },
      {
        name: 'Ārējās sienas',
        description:
          'Keramzītbetona bloki 300 mm 1. stāvā un 250 mm 2. un 3. stāvos, siltināti ar akmens vati 150 mm un apmesti ar dekoratīvo apmetumu.',
        provider: 'Jā',
      },
      {
        name: 'Koplietošanas telpu un starpdzīvokļu sienas, starpsienas',
        description:
          'Keramzītbetona bloki 250/200 mm ar apmetumu no abām pusēm.',
        provider: 'Jā',
      },
      {
        name: 'Dzīvokļa starpsienas',
        description:
