---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/ui/Container.astro';
import Section from '@/components/ui/Section.astro';
import BottomCTA from '@/components/layout/BottomCTA.astro';
import { getLocaleFromUrl, useTranslations, getLocalizedUrl } from '@/i18n/utils';
import { getApdaresSpec } from '@/i18n/apdares-spec';

const lang = getLocaleFromUrl(Astro.url);
const t = useTranslations(lang);
const groups = getApdaresSpec(lang);
---
<BaseLayout
  lang={lang}
  title={t('apdares.title')}
  description={t('apdares.description')}
>
  <!-- Hero -->
  <section class="relative bg-burgundy text-cream overflow-hidden">
    <div class="absolute inset-0 opacity-[0.06] pointer-events-none">
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_rgba(245,239,230,0.4),_transparent_60%)]"></div>
    </div>
    <Container class="relative py-24 md:py-32">
      <div class="max-w-3xl">
        <p class="text-[11px] md:text-xs uppercase tracking-[0.5em] text-cream/60">{t('apdares.hero_kicker')}</p>
        <h1 class="mt-6 font-serif text-5xl md:text-7xl leading-[1.05]">{t('apdares.hero_title')}</h1>
        <p class="mt-7 text-base md:text-lg text-cream/80 leading-relaxed max-w-2xl">
          {t('apdares.hero_body')}
        </p>
        <div class="mt-10 flex flex-wrap gap-3">
          <a href={getLocalizedUrl('/dzivokli', lang)} class="inline-flex items-center justify-center rounded-lg bg-cream px-6 py-3 text-base font-medium text-burgundy transition-colors hover:bg-beige">
            {t('apdares.cta_pick_apt')}
          </a>
          <a href="#specifikacija" class="inline-flex items-center justify-center rounded-lg border border-cream/40 px-6 py-3 text-base font-medium text-cream transition-colors hover:bg-cream hover:text-burgundy">
            {t('apdares.cta_view_spec')}
          </a>
        </div>
      </div>
    </Container>
  </section>

  <!-- Specification table -->
  <Section background="cream" id="specifikacija">
    <Container>
      <div class="mb-12 md:mb-16 max-w-3xl">
        <p class="text-xs uppercase tracking-[0.3em] text-ink-muted">{t('apdares.intro_kicker')}</p>
        <h2 class="mt-4 font-serif text-3xl md:text-4xl text-burgundy leading-tight">
          {t('apdares.intro_title')}
        </h2>
        <p class="mt-5 text-ink-muted leading-relaxed">
          {t('apdares.intro_body')}
        </p>
      </div>

      <!-- Desktop table -->
      <div class="hidden md:block overflow-x-auto rounded-2xl border border-burgundy/10 bg-cream">
        <table class="w-full text-left text-sm">
          <thead>
            <tr class="bg-burgundy text-cream">
              <th class="font-medium uppercase tracking-[0.2em] text-[11px] px-6 py-4 w-[22%]">{t('apdares.table_name')}</th>
              <th class="font-medium uppercase tracking-[0.2em] text-[11px] px-6 py-4">{t('apdares.table_description')}</th>
              <th class="font-medium uppercase tracking-[0.2em] text-[11px] px-6 py-4 w-[12%] whitespace-nowrap">{t('apdares.table_provider')}</th>
              <th class="font-medium uppercase tracking-[0.2em] text-[11px] px-6 py-4 w-[18%]">{t('apdares.table_notes')}</th>
            </tr>
          </thead>
          <tbody>
            {groups.map((g) => (
              <>
                <tr class="bg-beige/60">
                  <td colspan="4" class="px-6 py-3 font-serif text-lg text-burgundy">
                    {g.title}
                  </td>
                </tr>
                {g.rows.map((row, i) => (
                  <tr class:list={[
                    'align-top border-t border-burgundy/10',
                    i % 2 === 1 ? 'bg-cream' : 'bg-cream/60',
                  ]}>
                    <td class="px-6 py-5 font-medium text-ink">{row.name ?? ''}</td>
                    <td class="px-6 py-5 text-ink-muted leading-relaxed">{row.description}</td>
                    <td class="px-6 py-5 text-ink-muted">{row.provider ?? '—'}</td>
                    <td class="px-6 py-5 text-ink-muted">
                      {row.image ? (
                        <a href={row.image} target="_blank" rel="noopener" class="block group">
                          <img
                            src={row.image}
                            alt={row.imageAlt ?? row.name ?? t('apdares.see_image')}
                            loading="lazy"
                            width="160"
                            height="120"
                            class="w-40 h-24 object-cover rounded-md ring-1 ring-burgundy/15 transition-transform duration-200 group-hover:scale-[1.03]"
                          />
                        </a>
                      ) : (
                        row.notes ?? '—'
                      )}
                    </td>
                  </tr>
                ))}
              </>
            ))}
          </tbody>
        </table>
      </div>

      <!-- Mobile cards -->
      <div class="md:hidden space-y-10">
        {groups.map((g) => (
          <div>
            <h3 class="font-serif text-2xl text-burgundy">{g.title}</h3>
            <div class="mt-4 space-y-3">
              {g.rows.map((row) => (
                <article class="overflow-hidden rounded-xl border border-burgundy/10 bg-cream">
                  {row.image && (
                    <a href={row.image} target="_blank" rel="noopener" class="block bg-beige/40">
                      <img
                        src={row.image}
                        alt={row.imageAlt ?? row.name ?? t('apdares.see_image')}
                        loading="lazy"
                        width="800"
                        height="600"
                        class="w-full h-44 object-cover"
                      />
                    </a>
                  )}
                  <div class="p-5">
                    {row.name && (
                      <h4 class="font-medium text-ink leading-tight">{row.name}</h4>
                    )}
                    <p class="mt-2 text-sm text-ink-muted leading-relaxed">{row.description}</p>
                    <dl class="mt-4 grid grid-cols-2 gap-3 text-xs">
                      <div>
                        <dt class="uppercase tracking-[0.2em] text-ink-muted/70">{t('apdares.table_provider')}</dt>
                        <dd class="mt-1 text-ink">{row.provider ?? '—'}</dd>
                      </div>
                      <div>
                        <dt class="uppercase tracking-[0.2em] text-ink-muted/70">{t('apdares.table_notes')}</dt>
                        <dd class="mt-1 text-ink">{row.notes ?? '—'}</dd>
                      </div>
                    </dl>
                  </div>
                </article>
              ))}
            </div>
          </div>
        ))}
      </div>
    </Container>
  </Section>

  <BottomCTA lang={lang} background="beige" />
</BaseLayout>
