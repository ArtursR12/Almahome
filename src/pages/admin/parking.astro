---
import { getCollection } from 'astro:content';
import AdminParkingEditor from '@/components/AdminParkingEditor.svelte';
import '@/styles/globals.css';

export const prerender = false;

const spots = (await getCollection('parking'))
  .map((entry) => entry.data)
  .sort((a, b) => a.number - b.number);

// All apartment numbers for the "linked apartment" dropdown.
const apartmentNumbers = (await getCollection('apartments'))
  .map((entry) => entry.data.number)
  .sort((a, b) => a - b);

const counts = {
  total:     spots.length,
  available: spots.filter((s) => s.status === 'available').length,
  reserved:  spots.filter((s) => s.status === 'reserved').length,
  sold:      spots.filter((s) => s.status === 'sold').length,
};

function typeLabel(type: string): string {
  return type === 'surface_ev_ready' ? 'Virszemes · EV' : 'Virszemes';
}
---
<!doctype html>
<html lang="lv" class="bg-zinc-950">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="robots" content="noindex, nofollow" />
  <title>AlmaHome — Admin · Autostāvvietas</title>
  <style is:global>
    html, body { background: #09090B; color: #E4E4E7; }
  </style>
</head>
<body class="min-h-screen bg-zinc-950 text-zinc-100">
  <header class="border-b border-zinc-800 bg-zinc-900/40 sticky top-0 backdrop-blur z-30">
    <div class="mx-auto max-w-6xl px-6 py-4 flex items-center justify-between flex-wrap gap-3">
      <div class="flex items-baseline gap-4">
        <a href="/admin" class="font-serif text-xl tracking-[0.25em] uppercase text-zinc-100 hover:text-zinc-300 transition-colors">Alma Home</a>
        <span class="text-xs uppercase tracking-widest text-zinc-500">Admin · Autostāvvietas</span>
      </div>
      <div class="flex items-center gap-3 text-sm">
        <a href="/admin" class="text-zinc-400 hover:text-zinc-100 transition-colors">Dzīvokļi</a>
        <a href="/admin/polygons" class="text-zinc-400 hover:text-zinc-100 transition-colors">Poligoni</a>
        <a
          href="/api/admin/report.xlsx"
          download
          class="inline-flex items-center gap-1.5 rounded-md bg-emerald-700/30 hover:bg-emerald-700/50 text-emerald-200 px-3 py-1.5 transition-colors"
        >
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
            <path d="M12 4v12m0 0l-4-4m4 4l4-4M4 20h16" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
          Excel
        </a>
        <a href="/" class="text-zinc-400 hover:text-zinc-100 transition-colors">↗ Publiskā vietne</a>
      </div>
    </div>
  </header>

  <main class="mx-auto max-w-6xl px-6 py-10">
    <h1 class="font-serif text-4xl text-zinc-50">Autostāvvietu pārvaldība</h1>
    <p class="mt-2 text-sm text-zinc-400">
      Mainot statusu vai cenu, AlmaHome GitHub repo tiek izveidots commit.
      Vietne tiek atjaunota automātiski pēc ~30 sekundēm.
    </p>

    <!-- Stats -->
    <div class="mt-8 grid grid-cols-2 md:grid-cols-4 gap-4">
      <div class="rounded-lg bg-zinc-900 border border-zinc-800 p-5">
        <div class="text-xs uppercase tracking-widest text-zinc-500">Kopā</div>
        <div class="mt-2 font-serif text-3xl text-zinc-50 tabular-nums">{counts.total}</div>
      </div>
      <div class="rounded-lg bg-zinc-900 border border-zinc-800 p-5">
        <div class="text-xs uppercase tracking-widest text-emerald-400/80">Pieejamas</div>
        <div class="mt-2 font-serif text-3xl text-emerald-300 tabular-nums">{counts.available}</div>
      </div>
      <div class="rounded-lg bg-zinc-900 border border-zinc-800 p-5">
        <div class="text-xs uppercase tracking-widest text-amber-400/80">Rezervētas</div>
        <div class="mt-2 font-serif text-3xl text-amber-300 tabular-nums">{counts.reserved}</div>
      </div>
      <div class="rounded-lg bg-zinc-900 border border-zinc-800 p-5">
        <div class="text-xs uppercase tracking-widest text-zinc-400">Pārdotas</div>
        <div class="mt-2 font-serif text-3xl text-zinc-300 tabular-nums">{counts.sold}</div>
      </div>
    </div>

    <!-- Table -->
    <div class="mt-10 rounded-xl bg-zinc-900 border border-zinc-800 overflow-hidden">
      <div class="hidden md:grid grid-cols-[64px_140px_1fr] gap-4 px-5 py-3 border-b border-zinc-800 text-xs uppercase tracking-widest text-zinc-500">
        <div>№</div>
        <div>Tips</div>
        <div>Statuss · Cena</div>
      </div>
      <ul class="divide-y divide-zinc-800">
        {spots.map((s) => (
          <li class="px-5 py-4 grid grid-cols-2 md:grid-cols-[64px_140px_1fr] gap-4 items-center">
            <div class="font-serif text-2xl text-zinc-50 tabular-nums">{s.number}</div>
            <div class="text-sm text-zinc-400">{typeLabel(s.type)}</div>
            <div class="col-span-2 md:col-span-1">
              <AdminParkingEditor client:load spot={{
                number: s.number,
                type: s.type,
                status: s.status,
                price: s.price,
                buyer_name:       s.buyer_name,
                buyer_contact:    s.buyer_contact,
                buyer_notes:      s.buyer_notes,
                linked_apartment: s.linked_apartment,
              }} apartmentNumbers={apartmentNumbers} />
            </div>
          </li>
        ))}
      </ul>
    </div>

    <p class="mt-8 text-xs text-zinc-500">
      <strong class="text-zinc-400">Tehniska piezīme:</strong>
      katra izmaiņa rada GitHub commit. Pārmērīgi klikšķi = pārmērīgi commit'i.
    </p>
  </main>
</body>
</html>
