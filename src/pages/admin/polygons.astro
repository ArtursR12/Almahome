---
import fs from 'node:fs';
import path from 'node:path';
import '@/styles/globals.css';

export const prerender = false;

// Read both polygon files fresh on every request — middleware enforces auth.
const apartmentsPath = path.join(process.cwd(), 'src', 'data', 'floor-plans.json');
const parkingPath    = path.join(process.cwd(), 'src', 'data', 'parking-spots.json');

const apartmentsData = JSON.parse(fs.readFileSync(apartmentsPath, 'utf-8')) as {
  image_width: number;
  image_height: number;
  floors: Array<{
    floor: number;
    image: string;
    apartments: Array<{ number: number; polygon: string }>;
  }>;
};

const parkingData = JSON.parse(fs.readFileSync(parkingPath, 'utf-8')) as {
  image: string;
  image_width: number;
  image_height: number;
  spots: Array<{ number: number; polygon: string }>;
};

// Pre-compute a max viewBox so the SVG element can render either dataset without
// re-creating the element. JS will swap the viewBox attr per dataset.
const initialView = apartmentsData; // boot on apartments view
---
<!doctype html>
<html lang="lv" class="bg-zinc-950">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="robots" content="noindex, nofollow" />
  <title>AlmaHome — Admin · Poligoni</title>
  <style is:global>
    html, body { background: #09090B; color: #E4E4E7; }
    /* Disable text selection inside the SVG editor for cleaner drag UX. */
    .editor-svg, .editor-svg * { user-select: none; -webkit-user-select: none; }
    .editor-svg .vertex-handle { cursor: grab; }
    .editor-svg .vertex-handle.dragging { cursor: grabbing; }
  </style>
</head>
<body class="min-h-screen bg-zinc-950 text-zinc-100">
  <header class="border-b border-zinc-800 bg-zinc-900/40 sticky top-0 backdrop-blur z-30">
    <div class="mx-auto max-w-7xl px-6 py-4 flex items-center justify-between gap-4 flex-wrap">
      <div class="flex items-baseline gap-4">
        <a href="/admin" class="font-serif text-xl tracking-[0.25em] uppercase text-zinc-100 hover:text-zinc-300 transition-colors">Alma Home</a>
        <span class="text-xs uppercase tracking-widest text-zinc-500">Admin · Poligoni</span>
      </div>
      <div class="flex items-center gap-3">
        <a href="/admin" class="text-sm text-zinc-400 hover:text-zinc-100 transition-colors hidden md:inline">Dzīvokļi</a>
        <a href="/admin/parking" class="text-sm text-zinc-400 hover:text-zinc-100 transition-colors hidden md:inline">Autostāvvietas</a>
        <span id="save-status" class="text-sm text-zinc-400 min-w-0 truncate max-w-[280px]"></span>
        <span id="dirty-dot" class="inline-block w-2 h-2 rounded-full bg-amber-400 opacity-0 transition-opacity" aria-hidden="true"></span>
        <button id="reset-btn" type="button" class="text-sm rounded-md bg-zinc-800 hover:bg-zinc-700 px-3 py-1.5 transition-colors">
          Atiestatīt
        </button>
        <button id="save-btn" type="button" class="text-sm rounded-md bg-emerald-600 hover:bg-emerald-500 disabled:opacity-50 disabled:cursor-not-allowed px-4 py-1.5 transition-colors font-medium">
          Saglabāt
        </button>
      </div>
    </div>
  </header>

  <main class="mx-auto max-w-7xl px-6 py-8">
    <div class="mb-6">
      <h1 class="font-serif text-3xl text-zinc-50">Poligonu rediģēšana</h1>
      <p class="mt-2 text-sm text-zinc-400 max-w-3xl">
        Klikšķis uz elementa, lai to izvēlētos — parādās punktu marķieri. Velc punktu, lai pārvietotu. Vēlreiz klikšķis uz izvēlētā elementa malas pievieno jaunu punktu (jābūt tuvu malai). Labais klikšķis uz punkta to dzēš (min. 3 punkti).
        Saglabājot, izmaiņas tiek commitētas GitHub un publicētas pēc ~30 sekundēm.
      </p>
    </div>

    <!-- Dataset switcher -->
    <div class="flex gap-2 mb-4">
      <button data-dataset="apartments" type="button" class="dataset-tab px-4 py-2 rounded-md text-sm font-medium bg-zinc-900 border border-zinc-800 text-zinc-300 hover:text-zinc-100 transition-colors">
        Dzīvokļi
      </button>
      <button data-dataset="parking" type="button" class="dataset-tab px-4 py-2 rounded-md text-sm font-medium bg-zinc-900 border border-zinc-800 text-zinc-300 hover:text-zinc-100 transition-colors">
        Autostāvvietas
      </button>
    </div>

    <!-- Floor tabs (only meaningful for apartments) -->
    <div id="floor-tabs-wrap" class="flex gap-2 mb-6">
      {apartmentsData.floors.map((f, i) => (
        <button
          data-floor-tab={i}
          type="button"
          class="floor-tab px-4 py-2 rounded-md text-sm font-medium bg-zinc-900 border border-zinc-800 text-zinc-300 hover:text-zinc-100 transition-colors"
        >
          {f.floor}. stāvs
        </button>
      ))}
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-[1fr_300px] gap-6">
      <div class="bg-zinc-900 border border-zinc-800 rounded-xl overflow-hidden">
        <svg
          id="editor-svg"
          viewBox={`0 0 ${initialView.image_width} ${initialView.image_height}`}
          class="editor-svg w-full h-auto block touch-none"
          xmlns="http://www.w3.org/2000/svg"
        >
          <image id="floor-image" href="" x="0" y="0" width={initialView.image_width} height={initialView.image_height} preserveAspectRatio="xMidYMid meet" />
          <g id="polys"></g>
          <g id="handles"></g>
        </svg>
      </div>
      <aside class="space-y-4">
        <div class="bg-zinc-900 border border-zinc-800 rounded-xl p-4">
          <div class="text-xs uppercase tracking-widest text-zinc-500 mb-2">Izvēlēts</div>
          <div id="polygon-meta" class="text-sm text-zinc-300 mb-2">— izvēlies elementu —</div>
          <pre id="polygon-info" class="text-[11px] text-emerald-300 whitespace-pre-wrap break-all font-mono leading-relaxed bg-zinc-950/70 rounded p-2 max-h-48 overflow-auto"></pre>
        </div>
        <div class="bg-zinc-900 border border-zinc-800 rounded-xl p-4">
          <div class="text-xs uppercase tracking-widest text-zinc-500 mb-3">Elementi</div>
          <div id="item-list" class="grid grid-cols-4 gap-1.5"></div>
        </div>
        <div class="bg-zinc-900 border border-zinc-800 rounded-xl p-4 text-xs text-zinc-400 space-y-2">
          <div><b class="text-zinc-200">Klikšķis</b> sarakstā vai uz poligona — izvēlas</div>
          <div><b class="text-zinc-200">Klikšķis</b> uz fona (kad izvēlēts tukšs) — sāk poligonu</div>
          <div><b class="text-zinc-200">Velkot</b> punktu — pārvieto</div>
          <div><b class="text-zinc-200">Klikšķis</b> 2. reizi uz malas — pievieno punktu</div>
          <div><b class="text-zinc-200">Labais klikšķis</b> uz punkta — dzēš</div>
        </div>
        <div class="bg-zinc-900 border border-zinc-800 rounded-xl p-4 text-xs text-zinc-500">
          <div class="flex items-center gap-2 mb-2"><span class="inline-block w-3 h-3 rounded bg-emerald-400/60 border border-emerald-400"></span> izvēlēts</div>
          <div class="flex items-center gap-2 mb-2"><span class="inline-block w-3 h-3 rounded bg-zinc-100/20 border border-zinc-100/50"></span> ir poligons</div>
          <div class="flex items-center gap-2"><span class="inline-block w-3 h-3 rounded border border-dashed border-amber-400/70"></span> tukšs</div>
        </div>
      </aside>
    </div>
  </main>

  <script is:inline define:vars={{ initialApartments: apartmentsData, initialParking: parkingData }}>
    'use strict';
    const SVG_NS = 'http://www.w3.org/2000/svg';

    // Two independent working copies + snapshots for Reset.
    const apartmentsSnapshot = JSON.stringify(initialApartments);
    const parkingSnapshot    = JSON.stringify(initialParking);

    const state = {
      apartments: JSON.parse(apartmentsSnapshot),
      parking:    JSON.parse(parkingSnapshot),
      dataset: 'apartments',   // 'apartments' | 'parking'
      floorIdx: 0,             // only meaningful when dataset === 'apartments'
      selectedNumber: null,    // selected polygon's number (apt# or spot#)
      dirty: { apartments: false, parking: false },
    };

    const svg          = document.getElementById('editor-svg');
    const floorImageEl = document.getElementById('floor-image');
    const polysG       = document.getElementById('polys');
    const handlesG     = document.getElementById('handles');
    const statusEl     = document.getElementById('save-status');
    const dirtyDot     = document.getElementById('dirty-dot');
    const polygonInfo  = document.getElementById('polygon-info');
    const polygonMeta  = document.getElementById('polygon-meta');
    const floorTabs    = document.querySelectorAll('[data-floor-tab]');
    const datasetTabs  = document.querySelectorAll('[data-dataset]');
    const floorTabsWrap= document.getElementById('floor-tabs-wrap');
    const saveBtn      = document.getElementById('save-btn');
    const resetBtn     = document.getElementById('reset-btn');
    const itemList     = document.getElementById('item-list');

    // === Active-view accessors ===
    function activeData() { return state.dataset === 'parking' ? state.parking : state.apartments; }
    function activeImage() {
      if (state.dataset === 'parking') return state.parking.image;
      return state.apartments.floors[state.floorIdx].image;
    }
    function activeWidth()  { return activeData().image_width; }
    function activeHeight() { return activeData().image_height; }
    function activeItems() {
      if (state.dataset === 'parking') return state.parking.spots;
      return state.apartments.floors[state.floorIdx].apartments;
    }
    function selectedItem() {
      if (state.selectedNumber == null) return null;
      return activeItems().find((i) => i.number === state.selectedNumber) || null;
    }
    function isDirty() { return state.dirty.apartments || state.dirty.parking; }
    function markDatasetDirty(v) {
      state.dirty[state.dataset] = v;
      const any = isDirty();
      dirtyDot.classList.toggle('opacity-0', !any);
      dirtyDot.classList.toggle('opacity-100', any);
    }
    function setStatus(msg) { statusEl.textContent = msg; }

    // === Polygon math ===
    function parsePoly(s) {
      if (!s) return [];
      return s.trim().split(/\s+/).filter(Boolean).map((pair) => {
        const [x, y] = pair.split(',').map(Number);
        return { x, y };
      });
    }
    function serializePoly(pts) {
      return pts.map((p) => `${Math.round(p.x)},${Math.round(p.y)}`).join(' ');
    }
    function eventToSvg(e) {
      const pt = svg.createSVGPoint();
      pt.x = e.clientX; pt.y = e.clientY;
      const ctm = svg.getScreenCTM();
      if (!ctm) return { x: 0, y: 0 };
      const local = pt.matrixTransform(ctm.inverse());
      return { x: local.x, y: local.y };
    }
    function projectOnSegment(p, a, b) {
      const dx = b.x - a.x, dy = b.y - a.y;
      const len2 = dx * dx + dy * dy;
      if (len2 === 0) return { x: a.x, y: a.y, t: 0 };
      let t = ((p.x - a.x) * dx + (p.y - a.y) * dy) / len2;
      t = Math.max(0, Math.min(1, t));
      return { x: a.x + t * dx, y: a.y + t * dy, t };
    }
    function dist(a, b) { return Math.hypot(a.x - b.x, a.y - b.y); }

    function insertVertexOnNearestEdge(item, point) {
      const pts = parsePoly(item.polygon);
      if (pts.length < 2) return false;
      let bestIdx = -1, bestDist = Infinity, bestProj = null;
      for (let i = 0; i < pts.length; i++) {
        const a = pts[i], b = pts[(i + 1) % pts.length];
        const proj = projectOnSegment(point, a, b);
        const d = dist(point, proj);
        if (d < bestDist) { bestDist = d; bestIdx = i; bestProj = proj; }
      }
      if (bestDist > 40) return false;
      pts.splice(bestIdx + 1, 0, { x: Math.round(bestProj.x), y: Math.round(bestProj.y) });
      item.polygon = serializePoly(pts);
      return true;
    }
    function deleteVertex(idx) {
      const sel = selectedItem(); if (!sel) return;
      const pts = parsePoly(sel.polygon);
      if (pts.length <= 3) {
        setStatus('Vismaz 3 punkti ir vajadzīgi.');
        return;
      }
      pts.splice(idx, 1);
      sel.polygon = serializePoly(pts);
      markDatasetDirty(true);
      renderHandles();
      renderSelectedPolyOnly();
      updateInfo();
    }

    // === Drawing mode: when an item has an empty polygon, click on the SVG to
    // seed a 3-point starter polygon at the clicked location ===
    function seedPolygonAt(item, point) {
      const cx = Math.round(point.x);
      const cy = Math.round(point.y);
      // Small 60x60 starter square so the user can immediately see + drag.
      const pts = [
        { x: cx - 30, y: cy - 30 },
        { x: cx + 30, y: cy - 30 },
        { x: cx,      y: cy + 30 },
      ];
      item.polygon = serializePoly(pts);
    }

    // === Render ===
    function render() {
      // Image + viewBox
      svg.setAttribute('viewBox', `0 0 ${activeWidth()} ${activeHeight()}`);
      floorImageEl.setAttribute('href', activeImage());
      floorImageEl.setAttribute('width', String(activeWidth()));
      floorImageEl.setAttribute('height', String(activeHeight()));
      polysG.innerHTML = '';
      handlesG.innerHTML = '';
      for (const item of activeItems()) {
        const isSel = item.number === state.selectedNumber;
        const g = document.createElementNS(SVG_NS, 'g');
        g.dataset.number = item.number;
        if (item.polygon && item.polygon.trim() !== '') {
          const poly = document.createElementNS(SVG_NS, 'polygon');
          poly.setAttribute('points', item.polygon);
          poly.setAttribute('fill', isSel ? 'rgba(52, 211, 153, 0.30)' : 'rgba(244, 244, 245, 0.12)');
          poly.setAttribute('stroke', isSel ? '#34D399' : 'rgba(244, 244, 245, 0.55)');
          poly.setAttribute('stroke-width', isSel ? '3' : '1.5');
          poly.setAttribute('vector-effect', 'non-scaling-stroke');
          poly.style.cursor = 'pointer';
          poly.addEventListener('click', (e) => onPolygonClick(e, item));
          g.appendChild(poly);

          // Centroid label
          const pts = parsePoly(item.polygon);
          const cx = pts.reduce((s, q) => s + q.x, 0) / pts.length;
          const cy = pts.reduce((s, q) => s + q.y, 0) / pts.length;
          const lbl = document.createElementNS(SVG_NS, 'text');
          lbl.setAttribute('x', String(cx));
          lbl.setAttribute('y', String(cy));
          lbl.setAttribute('text-anchor', 'middle');
          lbl.setAttribute('dominant-baseline', 'middle');
          lbl.setAttribute('fill', '#FAFAFA');
          lbl.setAttribute('font-family', 'Cormorant Garamond, Georgia, serif');
          lbl.setAttribute('font-size', isSel ? '28' : '20');
          lbl.setAttribute('font-weight', '600');
          lbl.setAttribute('pointer-events', 'none');
          lbl.setAttribute('paint-order', 'stroke');
          lbl.setAttribute('stroke', 'rgba(0,0,0,0.6)');
          lbl.setAttribute('stroke-width', '3');
          lbl.textContent = String(item.number);
          g.appendChild(lbl);
        }
        polysG.appendChild(g);
      }
      renderHandles();
      renderItemList();
      updateInfo();
    }

    function renderItemList() {
      itemList.innerHTML = '';
      for (const item of activeItems()) {
        const isSel = item.number === state.selectedNumber;
        const isEmpty = !item.polygon || item.polygon.trim() === '';
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.dataset.itemNumber = String(item.number);
        btn.textContent = String(item.number);
        btn.title = isEmpty ? 'tukšs — izvēlies un klikšķi uz fona, lai sāktu' : 'ir poligons';
        const baseClasses = [
          'h-9', 'rounded-md', 'text-sm', 'font-medium', 'tabular-nums',
          'border', 'transition-colors',
        ];
        const stateClasses = isSel
          ? ['bg-emerald-500/25', 'border-emerald-400', 'text-emerald-100']
          : isEmpty
            ? ['bg-zinc-900', 'border-amber-500/40', 'border-dashed', 'text-amber-200/80', 'hover:border-amber-400']
            : ['bg-zinc-800', 'border-zinc-700', 'text-zinc-100', 'hover:border-zinc-500'];
        btn.className = [...baseClasses, ...stateClasses].join(' ');
        btn.addEventListener('click', () => {
          state.selectedNumber = item.number;
          render();
        });
        itemList.appendChild(btn);
      }
    }

    function renderHandles() {
      handlesG.innerHTML = '';
      const sel = selectedItem(); if (!sel) return;
      const pts = parsePoly(sel.polygon);
      pts.forEach((p, idx) => {
        const c = document.createElementNS(SVG_NS, 'circle');
        c.setAttribute('cx', String(p.x));
        c.setAttribute('cy', String(p.y));
        c.setAttribute('r', '8');
        c.setAttribute('fill', '#34D399');
        c.setAttribute('stroke', '#09090B');
        c.setAttribute('stroke-width', '2');
        c.setAttribute('vector-effect', 'non-scaling-stroke');
        c.classList.add('vertex-handle');
        c.dataset.idx = String(idx);
        c.addEventListener('pointerdown', (e) => onHandlePointerDown(e, idx));
        c.addEventListener('contextmenu', (e) => { e.preventDefault(); deleteVertex(idx); });
        handlesG.appendChild(c);
      });
    }

    function renderSelectedPolyOnly() {
      const sel = selectedItem(); if (!sel) return;
      const g = polysG.querySelector(`g[data-number="${sel.number}"]`);
      if (!g) return;
      const poly = g.querySelector('polygon');
      if (poly) poly.setAttribute('points', sel.polygon);
      const pts = parsePoly(sel.polygon);
      const cx = pts.reduce((s, q) => s + q.x, 0) / pts.length;
      const cy = pts.reduce((s, q) => s + q.y, 0) / pts.length;
      const lbl = g.querySelector('text');
      if (lbl) { lbl.setAttribute('x', String(cx)); lbl.setAttribute('y', String(cy)); }
    }

    function updateInfo() {
      const sel = selectedItem();
      if (!sel) {
        polygonMeta.textContent = '— izvēlies elementu —';
        polygonInfo.textContent = '';
        return;
      }
      const isEmpty = !sel.polygon || sel.polygon.trim() === '';
      const ptsCount = isEmpty ? 0 : parsePoly(sel.polygon).length;
      const label = state.dataset === 'parking' ? 'Vieta' : 'Dzīvoklis';
      polygonMeta.textContent = `${label} Nr. ${sel.number} · ${isEmpty ? 'tukšs' : ptsCount + ' punkti'}`;
      polygonInfo.textContent = isEmpty ? '(klikšķi uz pamatfona, lai sāktu zīmēt)' : sel.polygon;
    }

    function onPolygonClick(e, item) {
      e.stopPropagation();
      if (item.number !== state.selectedNumber) {
        state.selectedNumber = item.number;
        render();
        return;
      }
      const point = eventToSvg(e);
      if (insertVertexOnNearestEdge(item, point)) {
        markDatasetDirty(true);
        renderHandles();
        renderSelectedPolyOnly();
        updateInfo();
        setStatus('Pievienots punkts.');
      }
    }

    let drag = null;
    function onHandlePointerDown(e, idx) {
      e.preventDefault();
      e.stopPropagation();
      const sel = selectedItem(); if (!sel) return;
      drag = { number: sel.number, idx, target: e.currentTarget };
      drag.target.setPointerCapture?.(e.pointerId);
      drag.target.classList.add('dragging');
      window.addEventListener('pointermove', onPointerMove);
      window.addEventListener('pointerup', onPointerUp, { once: true });
    }
    function onPointerMove(e) {
      if (!drag) return;
      const item = activeItems().find((i) => i.number === drag.number);
      if (!item) return;
      const pts = parsePoly(item.polygon);
      const p = eventToSvg(e);
      p.x = Math.max(0, Math.min(activeWidth(), p.x));
      p.y = Math.max(0, Math.min(activeHeight(), p.y));
      pts[drag.idx] = { x: Math.round(p.x), y: Math.round(p.y) };
      item.polygon = serializePoly(pts);
      drag.target.setAttribute('cx', String(pts[drag.idx].x));
      drag.target.setAttribute('cy', String(pts[drag.idx].y));
      const poly = polysG.querySelector(`g[data-number="${item.number}"] polygon`);
      if (poly) poly.setAttribute('points', item.polygon);
      markDatasetDirty(true);
    }
    function onPointerUp() {
      if (!drag) return;
      drag.target.classList.remove('dragging');
      drag = null;
      window.removeEventListener('pointermove', onPointerMove);
      renderSelectedPolyOnly();
      updateInfo();
    }

    // Background click: deselect, OR seed a new polygon if the currently
    // selected item has none yet.
    svg.addEventListener('click', (e) => {
      if (e.target === svg || e.target === floorImageEl) {
        const sel = selectedItem();
        if (sel && (!sel.polygon || sel.polygon.trim() === '')) {
          const p = eventToSvg(e);
          seedPolygonAt(sel, p);
          markDatasetDirty(true);
          render();
          setStatus(`Sākts poligons. Velc punktus, lai pielāgotu.`);
          return;
        }
        if (state.selectedNumber != null) {
          state.selectedNumber = null;
          render();
        }
      }
    });

    // === Tabs ===
    function setFloor(i) {
      state.floorIdx = i;
      state.selectedNumber = null;
      floorTabs.forEach((b, j) => {
        const active = j === i;
        b.classList.toggle('bg-emerald-500/15', active);
        b.classList.toggle('border-emerald-400/50', active);
        b.classList.toggle('text-emerald-200', active);
      });
      render();
    }
    floorTabs.forEach((btn, i) => {
      btn.addEventListener('click', () => setFloor(i));
    });

    function setDataset(name) {
      state.dataset = name;
      state.selectedNumber = null;
      datasetTabs.forEach((b) => {
        const active = b.dataset.dataset === name;
        b.classList.toggle('bg-burgundy', active);
        b.classList.toggle('text-cream', active);
        b.classList.toggle('border-burgundy', active);
        b.classList.toggle('bg-zinc-900', !active);
        b.classList.toggle('border-zinc-800', !active);
        b.classList.toggle('text-zinc-300', !active);
      });
      // Floor tabs only relevant when editing apartments.
      floorTabsWrap.classList.toggle('hidden', name !== 'apartments');
      // Recompute dirty dot.
      markDatasetDirty(state.dirty[name]);
      render();
    }
    datasetTabs.forEach((btn) => {
      btn.addEventListener('click', () => setDataset(btn.dataset.dataset));
    });

    // === Selection helpers from sidebar / outside (none yet, but ready for them) ===

    // === Save ===
    saveBtn.addEventListener('click', async () => {
      saveBtn.disabled = true;
      setStatus('Saglabā…');
      try {
        const endpoint = state.dataset === 'parking'
          ? '/api/admin/save-parking-polygons'
          : '/api/admin/save-polygons';
        const payload = state.dataset === 'parking' ? state.parking : state.apartments;
        const res = await fetch(endpoint, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        const body = await res.json().catch(() => ({}));
        if (!res.ok) throw new Error(body.error || `HTTP ${res.status}`);
        setStatus('Saglabāts. Vietne tiks atjaunota ~30 sekundēs.');
        state.dirty[state.dataset] = false;
        const any = isDirty();
        dirtyDot.classList.toggle('opacity-0', !any);
        dirtyDot.classList.toggle('opacity-100', any);
      } catch (err) {
        setStatus('Kļūda: ' + (err && err.message ? err.message : String(err)));
      } finally {
        saveBtn.disabled = false;
      }
    });

    // === Reset (current dataset only) ===
    resetBtn.addEventListener('click', () => {
      if (state.dirty[state.dataset] && !confirm('Atjaunot poligonus uz pēdējo saglabāto versiju?')) return;
      if (state.dataset === 'parking') {
        state.parking = JSON.parse(parkingSnapshot);
      } else {
        state.apartments = JSON.parse(apartmentsSnapshot);
      }
      state.selectedNumber = null;
      state.dirty[state.dataset] = false;
      const any = isDirty();
      dirtyDot.classList.toggle('opacity-0', !any);
      dirtyDot.classList.toggle('opacity-100', any);
      setStatus('Atiestatīts.');
      render();
    });

    // === Boot ===
    setDataset('apartments');
    setFloor(0);
  </script>
</body>
</html>
