---
// Decorative section divider — a thin horizontal line with a small diamond
// at the centre. Sits comfortably between major sections without competing
// with the heading hierarchy.

interface Props {
  class?: string;
  /** "burgundy" (default), "muted" for sections with strong ground colours. */
  tone?: 'burgundy' | 'muted';
}

const { class: className = '', tone = 'burgundy' } = Astro.props;
const stroke = tone === 'burgundy' ? '#5A1F2A' : '#6B5D52';
const opacity = tone === 'burgundy' ? '0.35' : '0.55';
---
<div class:list={['flex items-center justify-center gap-3 w-full', className]} aria-hidden="true">
  <span class="h-px flex-1 max-w-[120px]" style={`background-color: ${stroke}; opacity: ${opacity};`}></span>
  <svg class="h-2.5 w-2.5 shrink-0" viewBox="0 0 10 10" fill="none">
    <path d="M5 0 L10 5 L5 10 L0 5 Z" fill={stroke} fill-opacity={opacity} />
  </svg>
  <span class="h-px flex-1 max-w-[120px]" style={`background-color: ${stroke}; opacity: ${opacity};`}></span>
</div>
