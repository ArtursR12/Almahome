---
interface Props {
  name: string;
  label?: string;
  type?: string;
  placeholder?: string;
  required?: boolean;
  value?: string;
  error?: string;
  id?: string;
  autocomplete?: string;
  class?: string;
}
const {
  name,
  label,
  type = 'text',
  placeholder,
  required = false,
  value,
  error,
  id = name,
  autocomplete,
  class: className = '',
} = Astro.props;

const inputBase =
  'w-full rounded-lg border bg-cream px-4 py-3 text-ink placeholder-ink-muted/60 transition-colors duration-200 focus:outline-none focus:border-burgundy';
const borderCls = error ? 'border-burgundy-light' : 'border-ink-muted/30';
---
<div class={`flex flex-col gap-2 ${className}`}>
  {label && (
    <label for={id} class="text-sm font-medium text-ink">
      {label}{required && <span class="text-burgundy"> *</span>}
    </label>
  )}
  <input
    id={id}
    name={name}
    type={type}
    placeholder={placeholder}
    required={required}
    value={value}
    autocomplete={autocomplete}
    class={`${inputBase} ${borderCls}`}
  />
  {error && <span class="text-sm text-burgundy">{error}</span>}
</div>
