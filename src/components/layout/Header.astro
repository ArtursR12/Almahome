---
import Container from '@/components/ui/Container.astro';
import { useTranslations, getLocalizedUrl, getLocaleFromUrl, type Locale, LOCALES } from '@/i18n/utils';

interface Props {
  lang?: Locale;
}

const { lang = getLocaleFromUrl(Astro.url) } = Astro.props;
const t = useTranslations(lang);

const navItems: { label: string; path: string }[] = [
  { label: t('nav.home'),         path: '/' },
  { label: t('nav.par_namu'),     path: '/par-namu' },
  { label: t('nav.par_projektu'), path: '/par-projektu' },
  { label: t('nav.atteli'),       path: '/atteli' },
  { label: t('nav.dzivokli'),     path: '/dzivokli' },
  { label: t('nav.apdares'),      path: '/apdares' },
  { label: t('nav.kontakti'),     path: '/kontakti' },
];

const homeHref = getLocalizedUrl('/', lang);
const currentPath = Astro.url.pathname;

function buildHref(path: string): string {
  return getLocalizedUrl(path, lang);
}

function isActive(path: string): boolean {
  const href = buildHref(path);
  if (path === '/') return currentPath === href;
  return currentPath === href || currentPath.startsWith(`${href}/`);
}
---
<header class="sticky top-0 z-40 border-b border-ink-muted/15 bg-cream/85 backdrop-blur">
  <Container class="flex h-16 items-center justify-between gap-4">
    <a
      href={homeHref}
      class="font-serif text-xl tracking-[0.25em] uppercase text-burgundy whitespace-nowrap"
    >
      Alma Home
    </a>

    <nav class="hidden lg:flex items-center gap-7 text-sm">
      {navItems.map((item) => {
        const href = buildHref(item.path);
        return (
          <a
            href={href}
            class:list={[
              'text-ink hover:text-burgundy transition-colors',
              isActive(item.path) && 'text-burgundy',
            ]}
          >
            {item.label}
          </a>
        );
      })}
    </nav>

    <div class="flex items-center gap-3">
      <div class="hidden md:flex items-center gap-1 text-xs uppercase tracking-widest" data-lang-switcher>
        {LOCALES.map((code) => (
          <a
            href={getLocalizedUrl(currentPath, code)}
            data-locale={code}
            hreflang={code}
            class:list={[
              'px-2 py-1 transition-colors',
              code === lang ? 'text-burgundy font-medium' : 'text-ink-muted hover:text-burgundy',
            ]}
          >
            {code}
          </a>
        ))}
      </div>

      <button
        type="button"
        id="mobile-menu-toggle"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
        class="lg:hidden inline-flex items-center justify-center h-10 w-10 rounded-lg text-burgundy hover:bg-beige transition-colors"
      >
        <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
          <path d="M4 6h16M4 12h16M4 18h16" stroke-linecap="round" />
        </svg>
      </button>
    </div>
  </Container>

  <div id="mobile-menu" class="lg:hidden hidden border-t border-ink-muted/15 bg-cream">
    <Container class="py-4 flex flex-col gap-3">
      {navItems.map((item) => {
        const href = buildHref(item.path);
        return (
          <a
            href={href}
            class:list={[
              'py-2 text-base hover:text-burgundy transition-colors',
              isActive(item.path) ? 'text-burgundy font-medium' : 'text-ink',
            ]}
          >
            {item.label}
          </a>
        );
      })}
      <div class="flex items-center gap-2 pt-3 border-t border-ink-muted/15 text-xs uppercase tracking-widest" data-lang-switcher>
        {LOCALES.map((code) => (
          <a
            href={getLocalizedUrl(currentPath, code)}
            data-locale={code}
            hreflang={code}
            class:list={[
              'px-2 py-1 transition-colors',
              code === lang ? 'text-burgundy font-medium' : 'text-ink-muted hover:text-burgundy',
            ]}
          >
            {code}
          </a>
        ))}
      </div>
    </Container>
  </div>
</header>

<script>
  // Mobile menu toggle
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    const open = menu?.classList.toggle('hidden') === false;
    toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
  });

  // Persist the user's language choice for next visit. We listen on the lang
  // switcher links so the click also captures the value before the navigation.
  document.querySelectorAll<HTMLAnchorElement>('[data-lang-switcher] a[data-locale]').forEach((a) => {
    a.addEventListener('click', () => {
      try { localStorage.setItem('preferred-locale', a.dataset.locale!); } catch {}
    });
  });
</script>
