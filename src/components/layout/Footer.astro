---
import Container from '@/components/ui/Container.astro';
import { useTranslations, getLocalizedUrl, getLocaleFromUrl, type Locale } from '@/i18n/utils';

interface Props {
  lang?: Locale;
}
const { lang = getLocaleFromUrl(Astro.url) } = Astro.props;
const t = useTranslations(lang);

const navItems = [
  { label: t('nav.par_namu'),     path: '/par-namu' },
  { label: t('nav.par_projektu'), path: '/par-projektu' },
  { label: t('nav.dzivokli'),     path: '/dzivokli' },
  { label: t('nav.parkings'),     path: '/parkings' },
  { label: t('nav.apdares'),      path: '/apdares' },
  { label: t('nav.kontakti'),     path: '/kontakti' },
];

const homeHref    = getLocalizedUrl('/', lang);
const privacyHref = getLocalizedUrl('/privatums', lang);
const year        = new Date().getFullYear();
---
<footer class="border-t border-ink-muted/15 bg-beige">
  <Container class="py-14">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-10">
      <div class="space-y-4 md:col-span-1">
        <a href={homeHref} class="font-serif text-xl tracking-[0.25em] uppercase text-burgundy">
          Alma Home
        </a>
        <p class="text-sm text-ink-muted leading-relaxed">{t('footer.about_brief')}</p>
      </div>

      <div class="space-y-3">
        <h3 class="font-serif text-lg text-burgundy">{t('footer.section_contacts')}</h3>
        <address class="not-italic text-sm text-ink-muted leading-relaxed space-y-1">
          <div>Mores iela 15<br />Rīga, LV-1034</div>
          <div><a href={`tel:${t('site.phone_compact')}`} class="hover:text-burgundy transition-colors">{t('site.phone')}</a></div>
          <div><a href={`mailto:${t('site.email')}`} class="hover:text-burgundy transition-colors">{t('site.email')}</a></div>
        </address>
      </div>

      <div class="space-y-3">
        <h3 class="font-serif text-lg text-burgundy">{t('footer.section_navigation')}</h3>
        <ul class="text-sm text-ink-muted space-y-2">
          {navItems.map((item) => (
            <li><a href={getLocalizedUrl(item.path, lang)} class="hover:text-burgundy transition-colors">{item.label}</a></li>
          ))}
        </ul>
      </div>

      <div class="space-y-3">
        <h3 class="font-serif text-lg text-burgundy">{t('footer.section_legal')}</h3>
        <ul class="text-sm text-ink-muted space-y-2">
          <li><a href={privacyHref} class="hover:text-burgundy transition-colors">{t('footer.privacy_policy')}</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-12 pt-6 border-t border-ink-muted/15 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2 text-xs text-ink-muted">
      <span>{t('footer.copyright').replace('2026', String(year))}</span>
      <span>Mores iela 15, Rīga</span>
    </div>
  </Container>
</footer>
