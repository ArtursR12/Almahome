---
import '@/styles/globals.css';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import FloatingContacts from '@/components/layout/FloatingContacts.astro';
import SEO from '@/components/SEO.astro';
import { getLocaleFromUrl, useTranslations, type Locale } from '@/i18n/utils';

interface Props {
  title?: string;
  description?: string;
  lang?: Locale;
  ogImage?: string;
  noindex?: boolean;
  /** Additional schema.org entities for this page (Apartment, ItemList, etc.). */
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const detectedLang = getLocaleFromUrl(Astro.url);
const {
  lang = detectedLang,
  ogImage = '/og-image.jpg',
  noindex = false,
  jsonLd,
} = Astro.props;

const t = useTranslations(lang);
const title       = Astro.props.title       ?? t('site.default_title');
const description = Astro.props.description ?? t('site.default_description');
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <SEO
      title={title}
      description={description}
      image={ogImage}
      lang={lang}
      jsonLd={jsonLd}
      noindex={noindex}
    />
    <meta name="generator" content={Astro.generator} />
  </head>
  <body class="min-h-screen flex flex-col">
    <a href="#main" class="skip-link">{t('common.skip_to_content')}</a>
    <Header lang={lang} />
    <main id="main" class="flex-1">
      <slot />
    </main>
    <Footer lang={lang} />
    <FloatingContacts lang={lang} />
  </body>
</html>

<style is:global>
  /* Skip-to-content link — visible only when focused via keyboard. */
  .skip-link {
    position: absolute;
    left: 50%;
    top: -40px;
    transform: translateX(-50%);
    z-index: 100;
    background: #5A1F2A;
    color: #F5EFE6;
    padding: 0.5rem 1rem;
    border-radius: 0 0 0.5rem 0.5rem;
    font-size: 0.875rem;
    transition: top 150ms;
  }
  .skip-link:focus { top: 0; outline: none; }
</style>
